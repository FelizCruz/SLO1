/* Chapter 3 */

//Encounter 1
"enc_c3e1o1_dialog_1a" = "Neden Trixie’yi götürüyorsunuz!?";
"enc_c3e1o1_dialog_2a" = "Yanlış zamanda yanlış yerdeydi. Şimdi geri çekil yoksa aynı şeyi sana da yaparız.";
"enc_c3e1o1_dialog_3a" = "Düşündüğümden iyisin. Ama yine de çok geç kaldın. Geri çekil!";

//Encounter 2
"enc_c3e2o1_dialog_1a" = "Eli Shane! Bizi aptal gibi gösterdin! Ateşle oynarsan yanarsın!";

"enc_c3e2o2_dialog_1a" = "Don!";
"enc_c3e2o2_dialog_2a" = "Ne zaman bırakılacağını bilmiyor musun?";

"enc_c3e2o3_dialog_1a" = "Seni dürüstçe yendim! Aş bunu artık!";
"enc_c3e2o3_dialog_2a" = "Sen BUNU aş!";
"enc_c3e2o3_dialog_3a" = "Bu iş bitmedi!";

//Encounter 3
"enc_c3e3o1_dialog_1a" = "Billy, seni burada durdurursam kendimi affettirebileceğimi söylüyor.";
"enc_c3e3o1_dialog_1b" = "Sonra da belki Holigan Çetesi’nin Gizli Evi’nde vakit geçirmeme izin verir.";
"enc_c3e3o1_dialog_2a" = "Of dostum. Artık hayatta Holigan Çetesi’ne giremem.";

//Encounter 4
"enc_c3e4o1_dialog_1a" = "Oh, harika. Billy’nin adamlarından biri daha.";
"enc_c3e4o1_dialog_2a" = "Ben Billy için çalışmıyorum! Benim çalıştığım kişi Doktor... Kimin için çalıştığımı boş ver.";
"enc_c3e4o1_dialog_2b" = "Bir dakika içinde senin icabına baktığımda bunun bir önemi olmayacak.";
"enc_c3e4o1_dialog_3a" = "O-oo. Patron bundan hiç hoşlanmayacak.";

//Encounter 5
"enc_c3e5o1_dialog_1a" = "Billy bir dövüşü kazanmayı becerememiş galiba, bu yüzden seni yok etmek için beni çağırdılar, yani Muhteşem Sedo’yu!";
"enc_c3e5o1_dialog_2a" = "Bir dahaki karşılaşmamızda Sedo bu kadar sevecen olmayacak!";

//Encounter 6
"enc_c3e6o1_dialog_1a" = "Sülükşörler Kralı? Burada ne işin var?";
"enc_c3e6o1_dialog_2a" = "Seni arıyordum! Ünvanımı geri almalıyım!";
"enc_c3e6o1_dialog_3a" = "Bir gün tahtımı senden geri alacağım, Eli Shane.";

//Encounter 7
"enc_c3e7o1_dialog_1a" = "Ahh! Sen nereden çıktın?";
"enc_c3e7o1_dialog_2a" = "Trixie’ye ne yaptınız?";
"enc_c3e7o1_dialog_3a" = "Beni rahat bırak! Ben hiçbir şey bilmiyorum.";
"enc_c3e7o1_dialog_4a" = "Trixie nerede?";
"enc_c3e7o1_dialog_5a" = "Şey... Gizli Ev’de değil, bu yüzden oraya gitme.";

//Encounter 8
"enc_c3e8o1_dialog_1a" = "Selam Eli! Holigan Çetesi’yle kapışmadan önce seninle biraz antrenman yapmalıyız. Onlar oldukça iyi sülükşörlerdir.";
"enc_c3e8o1_dialog_2a" = "Tamam Kord! Ama bana yumuşak davranma. Son karşılaşmamızdan çok daha güçlü durumdayım.";
"enc_c3e8o1_dialog_3a" = "Off. Şaka yapmıyormuşsun. Holigan Çetesi başına gelecekleri bilmiyor.";
"enc_c3e8o1_dialog_4a" = "Hadi bitirelim işlerini!";

//Encounter 9
"enc_c3e9o1_dialog_1a" = "Yalnız çalışmıyorsun. Trixie’yi kimin için kaçırdın?";
"enc_c3e9o1_dialog_2a" = "Ben kimse için çalışmıyorum! Oh, tabii Billy dışında... ve bir de Doktor Blakk... eyvah!";
"enc_c3e9o1_dialog_3a" = "Doktor Blakk mi? O da kim?";
"enc_c3e9o1_dialog_4a" = "Sana asla söylemem. Bitir işini Dörtgöz!";

"enc_c3e9o2_dialog_1a" = "Sürpriz!";

"enc_c3e9o3_dialog_1a" = "Sen de baban gibisin! İşimizi kurcalayan bir Shane’e ihtiyacımız yok bizim!";
"enc_c3e9o3_dialog_2a" = "Bu iş bitmedi Eli Shane! Doktor Blakk güçlü bir adam ve o her zaman istediğini alır! Hadi gidelim buradan!";

//Encounter 10

//Encounter 11
"enc_c3e11o1_dialog_1a" = "Bu sülüğe ne yaptın?";
"enc_c3e11o1_dialog_2a" = "Doktor Blakk onu hortlaklaştırdı! Şimdi gerçek gücü hissedeceksin!";
"enc_c3e11o1_dialog_3a" = "Sülükler her şeyin anahtarı! Bunu onlara nasıl yaparsınız?";
"enc_c3e11o1_dialog_4a" = "Doktor Blakk tüm sülükleri hortlaşklaştıracak! Onu durduramazsın!";

"enc_c3e11o2_dialog_1a" = "Sülükleri canavarlara dönüştürmenize seyirci kalmayacağım!";
"enc_c3e11o2_dialog_2a" = "Çok geç çocuk! El Diablos Nacho şu anda Doktor Blakk için başka bir hortlak sevkiyatına hazırlanıyor!";
"enc_c3e11o2_dialog_3a" = "Nerede bu sevkiyat?";
"enc_c3e11o2_dialog_4a" = "Yakıcı Kıvılcımlar Mağarası’nda… ama Nacho seni daha yaklaşmadan havaya uçurur! Bom!";

