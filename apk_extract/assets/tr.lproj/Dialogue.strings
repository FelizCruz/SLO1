"enc_c2e7o3_dialog_1a" = "Ve kaldı bir...";
"enc_c2e7o3_dialog_2a" = "Hiç adil değil. Üçün uğurlu sayın olduğunu bize söylemedin";
"enc_c2e7o3_dialog_3a" = "Başardık Kundakçı! Finallerdeyiz";
"enc_c2e7o3_dialog_3b" = "Bunu başarabileceğimizi biliyordum!";

//Encounter 8
"enc_c2e8o1_dialog_1a" = "Selam Eli. Şu ana kadar harikaydın ama dikkatli ol.";
"enc_c2e8o1_dialog_1b" = "Birisinin senin peşine düşmesi için bir adam tutuğuna dair söylentiler duydum.";
"enc_c2e8o1_dialog_2a" = "Neden birisi benim peşime düşsün ki?";
"enc_c2e8o1_dialog_3a" = "Slugterra’da babanı sevmeyenler de vardı. Birisi yeni bir Shane Çetesi görmek istemiyor olmalı!";
"enc_c2e8o1_dialog_4a" = "Söylediklerimi unutma! Kendine dikkat et!";

//Encounter 9

//Encounter 10
"enc_c2e10o1_dialog_1a" = "Korkarım turnuvanın son raundunda başarılı olamayacaksın Eli Shane.";
