//Encounter 4 - King of Sling
"enc_c9e4o1_dialog_1a" = "Yenilmez Usta’nın sırlarını öğrendiğimde, krallığım daha da kral olacak.";
"enc_c9e4o1_dialog_2a" = "Saçma. Gerçek bir kral hiçbir efendiye itaat etmez.";

//Encounter 5 - Trixie
"enc_c9e5o1_dialog_1a" = "Selam Trixie! Beni desteklemeye geldiğin için teşekkürler.";
"enc_c9e5o1_dialog_2a" = "Seni desteklemek mi? Buraya yarışmak için geldim. Bütün bunlar sadece senin için mi sandın?";

//Encounter 6 - Fake Duelist
"enc_c9e6o1_dialog_1a" = "Ustayla aramda sadece bir kişi kaldı.";
"enc_c9e6o1_dialog_1b" = "Tek sorun bu adam kim en ufak bir fikrim yok.";

//Encounter 7 - Unbeatable Master
"enc_c9e7o1_dialog_1a" = "Pekala, çarpık bacak, neler yapabilirsin görelim. Bu bir duello değil, bir sınav.";
"enc_c9e7o1_dialog_1b" = "Karar sadece bana ait.";

//Encounter 8 - Young Dr. Blakk
"enc_c9e8o1_dialog_1a" = "Bütün geceyi fırlatıcımı ayarlamakla geçirdim. Yenilmen kaçınılmaz.";
"enc_c9e8o1_dialog_2a" = "Sadece bir fırlatıcı ile sülükşör olamazsın, Thaddius!";
"enc_c9e8o1_dialog_2b" = "Yenileceksin!";

//Encounter 9 - Twist
"enc_c9e9o1_dialog_1a" = "Bu düelloyu kazanamayacaksın, Twist!";
"enc_c9e9o1_dialog_2a" = "Hiç belli olmaz, Eli.";
"enc_c9e9o1_dialog_3a" = "Yanlış adamı destekliyorsun, Twist... bunu sen de biliyorsun.";

//Encounter 10 - Dr. Blakk
"enc_c9e10o1_dialog_1a" = "Hayır.";
"enc_c9e10o1_dialog_2a" = "Afedersin?";
"enc_c9e10o1_dialog_3a" = "Hayır dedim. Bu kadar yeter. Bir daha asla masum bir insanı incitip yoluna devam edemeyeceksin.";

/* End Chapter 9 */

/* Chapter 10 */


//Encounter 1 - Broken Auto-Cannon
"enc_c10e1o1_dialog_1a" = "Yeni müdür beni Hurda Yığını’na senin yüzünden gönderdi, Tutuklu #371.";
"enc_c10e1o1_dialog_1b" = "İntikamımı ala…zzzttt…ca…bzzztt...ğım.";

//Encounter 2 - Doombot 1.0 & Doombot 2.0
"enc_c10e2o1_dialog_1a" = "Doombot 1.0? Burada ne işin var?";
"enc_c10e2o1_dialog_2a" = "Doombot programı piyasadan kalkınca, bütün Doombotlar buraya gönderildi.";
"enc_c10e2o1_dialog_2b" = "Doombot 1.0 savaş programını başlat!";
"enc_c10e2o2_dialog_1a" = "Doombot 2.0 demonte ol? Demonte olmaya hayır!";
"enc_c10e2o2_dialog_1b" = "Doombot 2.0 saldırı modeli 0101001110001'i başlat";

//Encounter 3 - Mecha-Mole
"enc_c10e3o1_dialog_1a" = "GRAAA-bzzzzzzzzt-AAAAAAR";
"enc_c10e3o1_dialog_1b" = "Bu sesi daha önce duymuştum!";

//Encounter 4 - Tough Guy Gang Member #1 -
"enc_c10e4o1_dialog_1a" = "Patron Ember’ın emri olmadan bu bölgeye giremezsin.";
"enc_c10e4o1_dialog_1b" = "Bütün sülüklerinizi ve fırlatıcılarınızı bırakıp geldiğiniz gibi Derin Depo’yu terk edin.";
"enc_c10e4o1_dialog_2a" = "Mümkün değil.";

//Encounter 5 - Tough Guy Gang Member #2 - Welder
"enc_c10e5o1_dialog_1a" = "Siz de kimsiniz?";
"enc_c10e5o1_dialog_2a" = "Biz Shane çetesiyiz. Belki adımızı duymuşsundur.";
"enc_c10e5o1_dialog_3a" = "Öyle mi. Belki sen de bizim adımızı duymuşsundur: İri Yarı Adamlar.";

//Encounter 6 - Tough Guy Gang Member #3 - Neckbrace
"enc_c10e6o1_dialog_1a" = "Burada parçalar bedava olabilir... ama onlara ulaşmanın bir bedeli var.";
"enc_c10e6o1_dialog_1b" = "Patron Ember’a bunun için hesap vereceksiniz.";

//Encounter 7 - Tough Guy Gang Member #4 - Troll
"enc_c10e7o1_dialog_1a" = "Hadi ama, beyler. Bu kristal sizin işinize yaramaz. Onu almamıza izin verirseniz burayı terk ederiz.";
"enc_c10e7o1_dialog_2a" = "Buna Patron Ember karar verecek.";

//Encounter 8 - Boss Ember
"enc_c10e8o1_dialog_1a" = "Derin Depo’nun müdürü benim. Hiç bir kişi veya parça benim iznim olmadan buradan çıkamaz.";
"enc_c10e8o1_dialog_1b" = "Durum bu, Shane. Sen ve ben. Teke tek. Kazanırsan Vitalis Kristali senin. Kaybedersin fırlatıcını alırım.";

//Encounter 9

//Encounter 10 - Angry Boss Ember
"enc_c10e10o1_dialog_1a" = "Sen üçkâğıtçının tekisin, Patron ember. Ben kazandım, hem de hakkımla! Vitalis kristalini bana ver!";
"enc_c10e10o1_dialog_2a" = "Yalan söyledim. Hiçbir yere gitmiyorsun, Shane. Burası BENİM hurda yığınım.";

/* End Chapter 10 */

/* Chapter 11 */

//Encounter 1 - Glasses
"enc_c11e1o1_dialog_1a" = "Herkesin elleri havaya! Hooligang aç ve susamış bir durumda ve ücretsiz süt bardakları ile yenebilecek kadar fıstık istiyor!";

//Encounter 2 - Shorty
"enc_c11e2o1_dialog_1a" = "Ünlü bir kötü adam olmadan önce eli çabuk bir aşçıydım.";

//Encounter 3 - Billy
"enc_c11e3o1_dialog_1a" = "Gene mi sen!";
"enc_c11e3o1_dialog_1b" = "Çekil yolumdan Eli! Açım ve üç gündür kurumuş sülük topakları yiyorum!";
"enc_c11e3o1_dialog_2a" = "Sen neden... hayır... Bunu sormayacağım.";

//Encounter 4 - Jeen
"enc_c11e4o1_dialog_1a" = "Burada ne yapıyorsunuz beyler? Hooligang için mi çalışıyorsunuz?";
"enc_c11e4o1_dialog_1b" = "Shame Çetesi intikam istiyor! Jeen favorileriyle Eli Shane'i beraber göğüs presi yapacak!";
"enc_c11e4o1_dialog_1c" = "Burada Hooligang ile birlikte olmadığına emin misin? Onlar da biraz önce buradaydı da!";

//Encounter 5 - Trapsie
"enc_c11e5o1_dialog_1a" = "Jeen'in favorileri ile boy ölçüşebilirsin ama benimle boy ölçüşemezsin!";

//Encounter 6 - Alias
"enc_c11e6o1_dialog_1a" = "Daha az yakışıklı ikizime bak hele! Sedo dışarıda! Şimdi Shame Çetesi'nin lideri benim ve intikam   istiyorum!";

//Encounter 7 - Welder Walter & Lil Stevie
"enc_c11e7o1_dialog_1a" = "İri Yarı Adamlar mı? Patron Ember ile neden tekrar çalışmıyorsun?";
"enc_c11e7o1_dialog_1b" = "İri Yarı Adamlar yeterince sıkı olmadıkları için işten atıldılar. Şimdi belâ ararken ayrıca iş de arıyoruz!";
"enc_c11e7o1_dialog_2a" = "Hey Eli! Shane Çetesi'nde personel açığınız var mı? Al, bu benim kötü adam özgeçmişim!";

//Encounter 8 - Mongo
"enc_c11e8o1_dialog_1a" = "Şu anda gönüllü olarak çalışıyorum! Bedavaya!";
"enc_c11e8o1_dialog_2a" = "Eli'yi düelloda bedava haklamaya gönüllüyüm! Hemen Şimdi!";

//Encounter 9 - Straggus
"enc_c11e9o1_dialog_1a" = "Kötü adam kaskım için yeni lambalar alacak param yok! Bu beni o kadar kızdırıyor ki!";

//Encounter 10 - Billy, Alias & Straggus
"enc_c11e10o1_dialog_1a" = "Hooligang, Shame Çetesi ve İri Yarı Adamlar? Neden hepiniz buradasınız?";
"enc_c11e10o1_dialog_1b" = "Bazılarımız aç, bazılarımız yakışıklı ve intikam istiyor ve bazılarımızın da yeni birer işe ihtiyacı var! Birlikte çalıştığımızda bizi hiç bir şey durduramaz!";
"enc_c11e10o2_dialog_2a" = "İntikam peşinde koşmam bazı yeni kötü dostlarla tanışmamı sağladı!";
"enc_c11e10o3_dialog_3a" = "İyi dostların yardımıyla kötü adamlara layık görevleri tamamlamanın daha kolay olduğunu öğrenmiş bulunuyorum.";
"enc_c11e10o3_dialog_4a" = "İşinizi dışarıda halledin beyler!";
"enc_c11e10o3_dialog_5a" = "Kaybettiğimize inanamıyorum, hem de dostluğun kötü gücüyle bile!";

/* End Chapter 11 */

/* Chapter 12 */


//Encounter 1 - Blakk Soldier & John Bull
"enc_c12e1o1_dialog_1a" = "Dur bakalım kabadayı! Dr. Thadeus Blakk adına tutuklusun!";
"enc_c12e1o1_dialog_2a" = "Tutuklu mu? Suçlama nedir?";
"enc_c12e1o1_dialog_1b" = "Ruhsatsız sapan kullanmak!";
"enc_c12e1o1_dialog_3a" = "Kaçacak hiçbir yerin yok, Shane! Arkanda büyük bir uçurum var!";

//Encounter 2 - Nacho
"enc_c12e2o1_dialog_1a" = "Fırlatıcıyı teslim et, biz de seni çok zorlamayalım!";
"enc_c12e2o1_dialog_2a" = "Bu teklifi reddedeceğim!";
"enc_c12e2o1_dialog_3a" = "Arkana bakma, Eli! Burası çok yüksek!";
"enc_c12e2o2_dialog_4a" = "Yüksekten korkuyor musun, Nacho? Çünkü ben korkmuyorum!";

//Encounter 3 - Darkbane Soldier 1
"enc_c12e3o1_dialog_1a" = "Vay canına! Nesin sen böyle?";
"enc_c12e3o1_dialog_1b" = "Vraaaooorrrr!!!!!";
"enc_c12e3o1_dialog_2a" = "Alev toplarına dikkat et!";

//Encounter 4 - Darkbane Soldier 2
"enc_c12e4o1_dialog_1a" = "Bİr tane daha! Bu şeyler nereden çıkıp geliyor?";

//Encounter 5 - Darkbane Soldier 3
"enc_c12e5o1_dialog_1a" = "Vraooor!!!";
"enc_c12e5o1_dialog_2b" = "Hadi Kundakçı! Bunun asıl kaynağını bulmalıyız!";

//Encounter 6 - Shadow Clan Protector
"enc_c12e6o1_dialog_1a" = "Durun! Burası kutsal topraklar. Geçemezsiniz!";
"enc_c12e6o1_dialog_2a" = "Bir dakika! Ben Eli Shane'im!";
"enc_c12e6o1_dialog_3a" = "Sülük Kapısı sarsılıyor! Eğer sen gerçekten Shane isen, Sülük Kapısı'nı korumalı ve Kara Kötülük'ü durdurmalısın!";
"enc_c12e6o1_dialog_4a" = "Bu Kara Kötülük kim bilmiyorum ama sana yardım edeceğim!";
"enc_c12e6o1_dialog_3b" = "Derin Mağaralar karanlık ve kötü enerjiyle dolu! Gözlerini dört aç, genç Shane!";

//Encounter 7 - Prison Door
"enc_c12e7o1_dialog_1a" = "Tamamdır Kundakçı! Umarım ne yaptığını biliyorsundur. Haydi şu kapıyı kıralım!";

//Encounter 8 - Prison Guards
"enc_c12e8o1_dialog_1a" = "Mahkum kaçtı! Alarmı çalın!";
"enc_c12e8o1_dialog_2a" = "Hortlakların seni kurtaramaz, zavallı insan!";
"enc_c12e8o1_dialog_3a" = "Hadi Kundakçı! Elimizi çabuk tutup buradan çıkmalıyız!";

//Encounter 9 - Prison Warden
"enc_c12e9o1_dialog_1a" = "Bir şiir yazdım! Adı \"Zavallı insan, hücrene geri dön!\" Dinlemek ister misin?";
"enc_c12e9o1_dialog_2a" = "Hımm.. tamam?";
"enc_c12e9o1_dialog_1b" = "Alev kızıldır, kayalar kara! Zavallı insan, hücrene geri dön!";
"enc_c12e9o1_dialog_2b" = "Kelimelerle nasıl oynayacağını biliyorsun!";

//Encounter 10 - Darkbane Nacho
"enc_c12e10o1_dialog_1a" = "Beni şaşırtıyorsun, Shane! Sadece kendini kurtarmak için sülüklerini hortlağa dönüştüreceğini hiç tahmin etmezdim!";
"enc_c12e10o1_dialog_2a" = "Bana başka seçenek bırakmadın! Slugterra'yı işgal etmene izin veremeyiz!";
"enc_c12e10o1_dialog_3a" = "Nerede olduğunu unuttun mu! Derin Mağaraların merkezinde kaybolmuş durumdasın! Artık çok geç, Eli Shane!";
"enc_c12e10o1_dialog_3b" = "Behemoth değerli Sülük Kapısı'nı yerle bir edecek ve Kara Kötülük Slugterra'daki yerini geri alacak!";

/* End Chapter 12 */

/* Chapter 13 */


//Encounter 1 - Darkbane 1
"enc_c13e1o1_dialog_1a" = "Sessiz bir kaçış için bu çok fazla!";

//Encounter 2 - Darkbane 2
"enc_c13e2o1_dialog_1a" = "Kara Kötülük'ün onuruna!";

//Encounter 3 - Darkbane 3
"enc_c13e3o1_dialog_1a" = "Kaçamazsınız!";

//Encounter 4 - Prison Warden
"enc_c13e4o1_dialog_1a" = "Bir şiir daha yazdım!";
"enc_c13e4o1_dialog_2a" = "Neden hiç şaşırmıyorum?";
"enc_c13e4o1_dialog_1b" = "Zavallı insan, çok küçüksün! Zavallı insan, uzun değilsin! Hücrene geri dön!";
"enc_c13e4o1_dialog_2b" = "Bir önceki şiirinden de kötüydü!";

//Encounter 5 - Bonus Round - Brimstone's Throne

//Encounter 6 - Darkbane Elite 1 & 2
"enc_c13e6o1_dialog_1a" = "Hey, dostlar!";
"enc_c13e6o1_dialog_2a" = "Kara Kötülük Elit'in dengi değilsiniz!";
"enc_c13e6o1_dialog_3a" = "Kara Kötülük'ün önünde diz çökün, ölümünüz hızlı olsun!";

//Encounter 7 - Darkbane Nacho
"enc_c13e7o1_dialog_1a" = "Kara Kötülük'ün sihrinin dengi değilsin!";
"enc_c13e7o1_dialog_2a" = "Sülüklerim senin için denkten de fazla! Onlar, Slugterra'nın gerçek muhafızları!";

//Encounter 8 - Angry Nacho
"enc_c13e8o1_dialog_1a" = "Nacho! Neler oluyor? Sen Kara Kötülük müsün?";
"enc_c13e8o1_dialog_2a" = "Artık sırrımı biliyorsun. Dr. Blakk bile bilmiyordu.";
"enc_c13e8o1_dialog_1b" = "Gitmene izin vermeyeceğim, Eli!";

//Encounter 9 - Behemoth
"enc_c13e9o1_dialog_1a" = "Vay! Sen çok kocaman bir arkadaşsın!";
"enc_c13e9o1_dialog_2a" = "Guarrrrrhhh!!!!!";
"enc_c13e9o1_dialog_3a" = "Ne kadar büyük olurlarsa o kadar zor düşüyorlar!";

//Encounter 10 - Brimstone
"enc_c13e10o1_dialog_1a" = "Kara Kötülük, Slugterra'nın hükümdarı olarak yerini geri alacak! Bu bizim kaderimiz!";
"enc_c13e10o1_dialog_2a" = "Geçmene izin vermeyeceğim!";
"enc_c13e10o1_dialog_1b" = "Bu mağarayı yerle bir edeceğim! Bu kapıyı alevler içinde bir kratere dönüştüreceğim!";
"enc_c13e10o1_dialog_3a" = "Hayııııııııır! Başarısız olmak için gereğinden fazla bekledim!";
"enc_c13e10o1_dialog_4a" = "Kundakçı! Brimstone'u geldiği yere gönder!";

/* End Chapter 13 */

/* Chapter 14 */


//Encounter 1 - Pronto, Kord and Trixie
"enc_c14e1o1_dialog_1a" = "Pronto'ya pratik yaptırmaya hazır mısın?";
"enc_c14e1o1_dialog_1b" = "Pronto düello yapmaya hep hazırdır! Pronto'nun molenoidler arasında ünlü bir sülükşör olduğunu biliyor muydun?";
"enc_c14e1o2_dialog_2a" = "Formunu kaybetmemelisin Eli! Zirvede kalmak için sülükşörlerin antrenman yapmaya ihtiyacı var!";
"enc_c14e1o2_dialog_2b" = "Hodri meydan!";
"enc_c14e1o3_dialog_3a" = "Yorgun görünüyorsun Eli! Bu, bir düelloda yenilmeni kolaylaştırır!";
"enc_c14e1o3_dialog_3b" = "Ne diyeceğim, biliyor musun? Kendimi biraz uykulu hissediyorum.";

//Encounter 2 - Dr.Blakk
"enc_c14e2o1_dialog_1a" = "Blakk! Burada ne işin var? Sen sülükşörlük turnuvalarına katılmazsın ki!";
"enc_c14e2o1_dialog_1b" = "Hayatımda seni daha önce hiç görmedim! Düelloya hazırlan, yabancı!";

//Encounter 3 - Spirex
"enc_c14e3o1_dialog_1a" = "Eli Shane! Ağa takılmış bir sinek misali, rüyalarında elin ayağın bağlı!";

//Encounter 4 - Eli
"enc_c14e4o1_dialog_1a" = "Sen... sen bensin! Neler oluyor burada?";
"enc_c14e4o1_dialog_2a" = "Dur bir dakika! Gerçek Eli Shane benim!";

//Encounter 5 - Young Blakk
"enc_c14e5o1_dialog_1a" = "Çok tanıdık görünüyorsun! Sen.. genç Dr. Blakk'e benziyorsun!";

//Encounter 6 - Behemoth
"enc_c14e6o1_dialog_1a" = "Hey, koca adam! Turnuvaya nasıl katıldın? Senin bir fırlatıcın bile yok!";
"enc_c14e6o1_dialog_2a" = "Vraaaaoooorrrrr!";

//Encounter 7 - Angry Blakk
"enc_c14e7o1_dialog_1a" = "Yine mi sen! Neden yoluma çıkmakta inat ediyorsun!";
"enc_c14e7o1_dialog_2a" = "Tavırların hep kötüydü zaten!";

//Encounter 8 - Unbeatable Master
"enc_c14e8o1_dialog_1a" = "Hayat bir yanılsamadan ibarettir, Eli! Gerçek bilgelik rüyalarda bulunabilir. Bulmaya can attığın kişiyi ara ve bul!";
"enc_c14e8o1_dialog_2a" = "Bekle! O kişiyi bulduğumu nasıl bileceğim?";
"enc_c14e8o1_dialog_2b" = "Aklının henüz öğrenmediğini kalbin zaten bilir!";

//Encounter 9 - Gat Blakk
"enc_c14e9o1_dialog_1a" = "Bu normal bir fırlatıcıya benzemiyor!";
"enc_c14e9o1_dialog_2a" = "Bu rüya senin olabilir, Eli Shane, fakat intikam benim olacak! Havaya uçurulmaya hazırlan!";

//Encounter 10 - Will Shane
"enc_c14e10o1_dialog_1a" = "Eli! Yulculuklarında pek çok tehlikeyle karşı karşıya kaldın. Bakalım neler öğrendin.";
"enc_c14e10o1_dialog_2a" = "Baba! Hayattasın! Seni her yerde aradım...";
"enc_c14e10o1_dialog_3a" = "Seninle o kadar gurur duyuyorum ki, evlat! Gerçekten büyük bir Shane oldun.";
"enc_c14e10o1_dialog_3b" = "Benimle geri gel! Sana sormak istediğim o kadar çok şey, o kadar sorum var ki...";
"enc_c14e10o1_dialog_3c" = "Eli, artık Shane sensin! Her şey umutsuz göründüğünde yine karşılaşacağız. Hoşça kal evlat.";

/* End Chapter 14 */

/* Chapter 15 */


//Encounter 1 - Dr.Blakk
"enc_c15e1o1_dialog_1a" = "Görüyorum ki mesajımı almışsın!";
"enc_c15e1o2_dialog_1a" = "Beni buraya neden çağırdın, Blakk?";
"enc_c15e1o1_dialog_2a" = "Burası çok önemli bir yer Eli. Neden, biliyor musun? Sana bir hikâye anlatayım.";

//Encounter 2 - Angry Miner
"enc_c15e2o1_dialog_1a" = "Burası Cenko Gözüpek'in yeri ve yeniyetmelerin yerlerini bilmesi gerekiyor!";
"enc_c15e2o2_dialog_1b" = "Başımın herhangi bir belaya girmesini istemiyorum!";

//Encounter 3 - Foreman
"enc_c15e3o1_dialog_1a" = "İzin ver geçeyim!";
"enc_c15e3o2_dialog_1a" = "Buradan öyle elini kolunu sallayarak gidemezsin. Sen artık Cenko Gözüpek'e aitsin!";

//Encounter 4 - The Heavy, The Rat
"enc_c15e4o1_dialog_1a" = "Şuraya bak hele! Bu o kaçak!";
"enc_c15e4o1_dialog_2a" = "Seni madenlere geri götürmemiz lazım! Patronun emri!";

//Encounter 5 - Young Will Shane
"enc_c15e5o1_dialog_1a" = "Durun! Siz iki vatandaşa kaba davranan kişiler misiniz?";
"enc_c15e5o2_dialog_1a" = "Ne? Onlar Cenko Gözüpek'in adamları. Onlar bana saldırdı!";
"enc_c15e5o2_dialog_1b" = "Ben Shane'im! Bu mağarada tekrar sorun çıkarmadan önce iki kere düşüneceksin!";

//Encounter 6 - Viggo, Dare, The Rat
"enc_c15e6o1_dialog_1a" = "Gene sen! Patron buna sevinmeyecek!";
"enc_c15e6o1_dialog_1b" = "Başıma çok dert açtın! Şimdi ben seni oraya sürüklemeden, madenlere geri dön!";
"enc_c15e6o2_dialog_1a" = "İtilip kakılmaktan bıktım! Artık burası benim mağaram! Fırlatıcını atarsan, buradan çıkıp gitmene izin veririm.";
"enc_c15e6o3_dialog_1a" = "Adamların artık benim adamlarım! Madenlerin artık benim madenlerim! Bu mağara artık benim mağaram ve sen sınırımı ihlal ediyorsun!";
"enc_c15e6o3_dialog_1b" = "Şimdi toz ol!";

//Encounter 7 - Will Shane
"enc_c15e7o1_dialog_1a" = "Blakk! Buradan bir tren geçireceksin diye bu insanları topraklarından kovmana izin vermeyeceğim!";
