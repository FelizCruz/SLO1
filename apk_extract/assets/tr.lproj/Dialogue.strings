/* Chapter 5 */


//Encounter 1
"enc_c5e1o1_dialog_1a" = "Doktor Blakk sülüklerimi çok daha güçlü yaptı. Bu defa sana yenilmeyeceğim!";
"enc_c5e1o1_dialog_2a" = "Blakk’in sülüklerini bozmasına izin verdin! Onları düzeltebilirim. Sadece yardım etmeme izin ver.";
"enc_c5e1o1_dialog_3a" = "Bu mümkün değil! Hadi düello yapalım!";
"enc_c5e1o1_dialog_4a" = "İşte! Artık sülüklerin normale döndü.";

//Encounter 2
"enc_c5e2o1_dialog_1a" = "Olamaz. Sedo! Artık sen de mi Blakk için çalışıyorsun?";
"enc_c5e2o1_dialog_2a" = "Olağanüstü Sedo en iyi anlaşmayı sunan için çalışır. Daha iyi bir teklifin var mı?";
"enc_c5e2o1_dialog_3a" = "...";
"enc_c5e2o1_dialog_4a" = "Sedo da öyle düşünmüştü.";

//Encounter 3
"enc_c5e3o1_dialog_1a" = "Beni iki kere rezil ettin. Bir kez daha bunu yapmana izin vermeyeceğim.";
"enc_c5e3o1_dialog_2a" = "Yanlış taraftasın John Bull. Bunu şimdiye kadar anlamadıysan hiçbir zaman anlamazsın.";
"enc_c5e3o1_dialog_3a" = "Ben kazanan taraftayım Shane ve bunu kanıtlayacak sülüklerim var.";
"enc_c5e3o1_dialog_4a" = "Kaybol John. Blakk’in sülükleri hortlağa dönüştürmesine son kez yardım ettin.";

//Encounter 4
"enc_c5e4o1_dialog_1a" = "Doombot 2.0 piyasaya sürüldü! Doombot 2.0, Doombot 1.0’a göre iki kat daha doombot.";
"enc_c5e4o1_dialog_2a" = "İstediğin gerçekten bu mu Doombot?";
"enc_c5e4o1_dialog_3a" = "Doombot buna engel olamıyor. Doombot bu şekilde programlanmış.";
"enc_c5e4o1_dialog_4a" = "Eli Shane haklı. Doombot 2.0 bu şiddet dolu yaşam tarzını bırakmak istiyor.";
"enc_c5e4o1_dialog_4b" = "Doombot 2.0 ressam olacak ve topluma borcunu sanatla ödeyecek.";

//Encounter 5
"enc_c5e5o1_dialog_1a" = " ‘Blakk’in kuklası değilim’ dememiş miydin?";
"enc_c5e5o1_dialog_2a" = "Blakk benim payımı iki katına çıkardı. Bay Cumartesi iyi anlaşmayı duyduğu an anlar.";
"enc_c5e5o1_dialog_3a" = "Beni yendin Shane ama şunu aklından çıkarma, senin için geri döneceğim.";

//Encounter 6
"enc_c5e6o1_dialog_1a" = "Shorty! Dörtgöz! Billy! Lütfen buna bir son verin. Sülükleri hortlaklaştırmak büyük bir hata. Slugterra buna dayanamaz.";
"enc_c5e6o1_dialog_2a" = "Sen sadece sülüklerimizin bu kadar güçlü olmasını kıskanıyorsun. Gerçek bir sülükşör nasıl olur sana göstereceğim.";

"enc_c5e6o2_dialog_1a" = "Endişelenme Shorty, Donarcam kaybedemez. Eli’ın işini bitireceğim.";
"enc_c5e6o2_dialog_2a" = "Anlamıyorsunuz. Blakk’in her şeyi mahvetmesine yardım ediyorsunuz. Durmak zorundasınız.";
"enc_c5e6o2_dialog_3a" = "Oof. Billy bize yardım et!";

"enc_c5e6o3_dialog_1a" = "Billy lütfen... dinle beni... boyundan büyük işlere kalkışıyorsun.";
"enc_c5e6o3_dialog_2a" = "Çok geç, Eli. Biz seçimimizi yaptık.";
"enc_c5e6o3_dialog_3a" = "Asla çok geç değildir. Blakk nerede?";

//Encounter 7
"enc_c5e7o1_dialog_1a" = "Höpür Hapır Küpür!";
"enc_c5e7o1_dialog_2a" = "Sanırım bana saldırmaman için seni ikna etmem mümkün değil.";
"enc_c5e7o1_dialog_3a" = "Bir hamburgerden daha lezzetli olan tek şey, seni alt etmek.";
"enc_c5e7o1_dialog_4a" = "Blakk’i bulmak ve buna bir son vermek zorundayım.";

//Encounter 8
"enc_c5e8o1_dialog_1a" = "Demek Shane Çetesi tuzağımızın tam içine düştü. Kilitle ve doldur!";
"enc_c5e8o1_dialog_1b" = "Senin icabına baktıktan sonra, tüm sülüklerini hortlaklaştırması için Blakk’e vereceğim!";
"enc_c5e8o1_dialog_2a" = "Sülüklerime el sürmene asla izin vermem.";
"enc_c5e8o1_dialog_3a" = "Lode! Hazırlan. Bu çocuğu yenmemiz gerek.";

"enc_c5e8o2_dialog_1a" = "Lode! Locke’un söylediklerini yapmak zorunda değilsin. Sülüklerini iyileştirmeme izin ver.";
"enc_c5e8o2_dialog_2a" = "Locke kaybolmuş olabilir ama senin işini ben bitireceğim! Bom!";
"enc_c5e8o2_dialog_3a" = "Kaç! Kaç!";

//Encounter 9
"enc_c5e9o1_dialog_1a" = "Baban sana geceleri ortaya çıkan korkutucu canavarları anlattığında benden bahsediyordu Shane.";
"enc_c5e9o1_dialog_1b" = "Ben, korkman gerektiği öğretilen her şeyim. Ben karanlığım. Ben umutsuzluğum.";
