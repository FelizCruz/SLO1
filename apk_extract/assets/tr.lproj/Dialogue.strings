"enc_c5e9o1_dialog_2a" = "Babam bana başka bir hikaye anlattı. Korkunun kendini güçlendirdiğini sanan canavarların her zaman kaybettiği hikaye...";
"enc_c5e9o1_dialog_2b" = "Ama ben senden korkmuyorum.";
"enc_c5e9o1_dialog_3a" = "Yenildin Nacho. Şimdi bana Blakk’in nerede olduğunu söyle.";

//Encounter 10
"enc_c5e10o1_dialog_1a" = "İstediğin kadar savaşabilirsin ama ben tüm Slugterra’ya HÜKMEDECEĞİM.";
"enc_c5e10o1_dialog_1b" = "Yeni bir dünya düzeni tasarladım ve sen Eli Shane, bu çarkın dişlileri arasında ezileceksin.";
"enc_c5e10o1_dialog_2a" = "Sen boş bir arazinin hakimi olacaksın. Sülükler olmadan Slugterra varlığını devam ettiremez.";
