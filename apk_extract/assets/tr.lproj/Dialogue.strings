"enc_c2e6o1_dialog_2a" = "Arkadaşça sözlerle Pronto’nun dikkatini dağıtmaya çalışma!";

//Encounter 7
"enc_c2e7o1_dialog_1a" = "Bu raundu kesinlikle geçememen için üç iyi nedenimiz var.";
