/* Chapter 1 */

//Encounter 1
"enc_c1e1o1_dialog_1a" = "Harika! Bir mağara trolü. Hep bir mağara trolüyle tanışmak istemişimdir!";
"enc_c1e1o1_dialog_2a" = "Ben Kord Zane. Sen buralardan değilsin, değil mi?";
"enc_c1e1o1_dialog_2b" = "Sana kendini nasıl savunacağını öğretsem iyi olur. Aşağıdaki taş bloklarına bak.";
"enc_c1e1o1_dialog_3a" = "Bir taşa dokunarak ve onu yanındaki taşın yerine sürükleyerek taşları hareket ettirmeye çalış.";
"enc_c1e1o1_dialog_4a" = "Aferin, evlat. Yeterli.";
"enc_c1e1o1_dialog_5a" = "Pekala Eli, şimdi sana taşları nasıl eşleyeceğini göstereceğim.";
"enc_c1e1o1_dialog_6a" = "Bakalım üç fırlatıcı taşını eşleyebilecek misin?";
"enc_c1e1o1_dialog_7a" = "Oof! Bu senin ateşlediğin ilk fırlatıcıydı!?! Beni vurabilmiş olmana imkan yok.";
"enc_c1e1o1_dialog_7b" = "Eminim bunu bir kez daha yapamazsın.";
"enc_c1e1o1_dialog_8a" = "Bir eşleştirme daha yapmak için fırlatıcı taşlarını hareket ettir!";
"enc_c1e1o1_dialog_9a" = "Ah! Tamam, demek atış konusunda oldukça iyisin… ama buradaki tek fırlatıcı sen değilsin! Hadi düello yapalım!";
"enc_c1e1o1_dialog_10a" = "Ay! Oh! Of! Bunu neden yaptın? Doğru ya, ben demiştim...";

//Encounter 2
"enc_c1e2o1_dialog_1a" = "İyi iş çıkardın evlat! Sıradaki adım, iyileşme";
"enc_c1e2o1_dialog_2a" = "Sağlık çubuğunu doldurmak için üç yeşil sağlık taşını eşle.";
"enc_c1e2o1_dialog_3a" = "Kendini daha iyi hissediyor musun? Güzel!";
"enc_c1e2o1_dialog_4a" = "Üzgünüm, fırlatıcım biraz hassas. Tekrar iyileşsen iyi olur.";
"enc_c1e2o1_dialog_5a" = "Bu dört sağlık taşını eşleştirmeye çalış.";
"enc_c1e2o1_dialog_6a" = "Bir hamlede ne kadar  fazla taş eşleştirebilirsen o kadar iyi.";
"enc_c1e2o1_dialog_6b" = "Bakalım düelloda kendini ne kadar koruyabileceksin.";
"enc_c1e2o1_dialog_7a" = "Tüh. Kazanmaya çok yakındım.";
"enc_c1e2o1_dialog_8a" = "Bana öğretiyor olman gerekmiyor mu?";
"enc_c1e2o1_dialog_9a" = "Şey, doğru. Bu bir testti… ve sen geçtin!";

//Encounter 3
"enc_c1e3o1_dialog_1a" = "Dostum! O gördüğüm bir Yakıcı sülük mü?";
"enc_c1e3o1_dialog_2a" = "Onun adı Kundakçı. O müthiştir.";
"enc_c1e3o1_dialog_3a" = "Yakıcı sülükler güçlü ateş yaratıklarına dönüşürler.";
"enc_c1e3o1_dialog_4a" = "Kundakçı dönüşüm antrenmanı yapmak istediğini söylüyor.";
"enc_c1e3o1_dialog_5a" = "Kundakçı’yı saldırıya hazır hale getirmek için ateş taşlarını eşleştirmeye çalış!";
"enc_c1e3o1_dialog_6a" = "Devam et! Daha fazla meyve suyuna ihtiyacı var.";
"enc_c1e3o1_dialog_7a" = "Bir defada beş ateş taşını eşleşleştirmek Kundakçı’yı birinci seviyede şarj eder.";
"enc_c1e3o1_dialog_8a" = "Artık Kundakçı hazır hale geldi, yeni saldırısını yapması için sülüğüne dokun!";
"enc_c1e3o1_dialog_9a" = "Ah ah ah ah. Tamam. Bence işi kavradın. Düello!";
"enc_c1e3o1_dialog_10a" = "Ah! Bir dahaki sefere pantolonumu tutuşturmamaya çalış!";
"enc_c1e3o1_dialog_10b" = "Bence ilk gerçek düellonu yapmaya hazırsın! PRONTO!!!!";

/* End Chapter 1 */

