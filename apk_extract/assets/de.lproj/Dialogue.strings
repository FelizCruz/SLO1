"enc_c3e5o1_dialog_1a" = "Seems Billy couldn’t handle a fight, so I, Sedo the Magnificent, have been called to destroy you!";
"enc_c3e5o1_dialog_2a" = "When next we meet Sedo will not be so congenial!";

//Encounter 6
"enc_c3e6o1_dialog_1a" = "King of Sling? What are you doing out here?";
"enc_c3e6o1_dialog_2a" = "I've been looking for you! I must reclaim my title!";
"enc_c3e6o1_dialog_3a" = "One day I will retake my throne from you, Eli Shane.";

//Encounter 7
"enc_c3e7o1_dialog_1a" = "Ahh! Where did you come from?";
"enc_c3e7o1_dialog_2a" = "What have you done with Trixie?";
"enc_c3e7o1_dialog_3a" = "Leave me alone! I don't know anything.";
"enc_c3e7o1_dialog_4a" = "Where is Trixie?";
"enc_c3e7o1_dialog_5a" = "Uh...She's not at the hideout, so don't go there.";

//Encounter 8
"enc_c3e8o1_dialog_1a" = "Hey Eli! We should practice a bit before you take on the Hooligang. They are all pretty good slugslingers.";
"enc_c3e8o1_dialog_2a" = "Okay Kord! But don't go easy on me. I'm way stronger than I was the last time we faced off.";
"enc_c3e8o1_dialog_3a" = "Oof. You weren't kidding. The Hooligang won't see it coming.";
"enc_c3e8o1_dialog_4a" = "Let's get 'em!";

//Encounter 9
"enc_c3e9o1_dialog_1a" = "You aren't working alone. Who did you kidnap Trixie for?";
"enc_c3e9o1_dialog_2a" = "I work for no one! Oh, except that I work for Billy... and also Doctor Blakk... oops!";
"enc_c3e9o1_dialog_3a" = "Dr. Blakk? Who is he?";
"enc_c3e9o1_dialog_4a" = "Like I would ever tell you. Get him, Glasses!";

"enc_c3e9o2_dialog_1a" = "Surprise!";

"enc_c3e9o3_dialog_1a" = "You're just like your father! We can't have a Shane poking around in our business!";
"enc_c3e9o3_dialog_2a" = "This isn't over Eli Shane! Dr. Blakk is a powerful man and he always gets what he wants! Let's get out of here!";

//Encounter 10

//Encounter 11
"enc_c3e11o1_dialog_1a" = "What did you do to that slug?";
"enc_c3e11o1_dialog_2a" = "Dr. Blakk ghouled him! Now you're gonna feel real power!";
"enc_c3e11o1_dialog_3a" = "Slugs are the key to everything! How can you do that to them?";
"enc_c3e11o1_dialog_4a" = "Dr. Blakk is gonna ghoul all slugs! You can't stop him!";

"enc_c3e11o2_dialog_1a" = "I won't sit back while you turn slugs into monsters!";
"enc_c3e11o2_dialog_2a" = "Too late kid! El Diablos Nacho is getting another shipment of ghouls ready for Dr. Blakk right now!";
"enc_c3e11o2_dialog_3a" = "Where is this shipment?";
"enc_c3e11o2_dialog_4a" = "They're in Scorched Sparks Cavern... but Nacho will blow you up before you even get close! Kaboom!";

