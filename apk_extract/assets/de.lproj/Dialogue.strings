"enc_c5e1o1_dialog_1a" = "Dr. Blakk made all of my slugs way stronger. This time I'm not going to lose to you!";
"enc_c5e1o1_dialog_2a" = "You've let Dr. Blakk corrupt your slugs! I can fix them. Just let me help.";
"enc_c5e1o1_dialog_3a" = "No way! Let's duel!";
"enc_c5e1o1_dialog_4a" = "There! Now your slugs are back to normal.";

//Encounter 2
"enc_c5e2o1_dialog_1a" = "Oh no. Sedo! You're working for Blakk now too?";
"enc_c5e2o1_dialog_2a" = "The spectacular Sedo works for the highest paying contract. Do you have a counter offer?";
"enc_c5e2o1_dialog_3a" = "...";
"enc_c5e2o1_dialog_4a" = "Sedo suspected as much.";

//Encounter 3
"enc_c5e3o1_dialog_1a" = "You have made a fool of me twice. I will not allow you to do so again.";
"enc_c5e3o1_dialog_2a" = "You are on the wrong side John Bull. If you haven't figured that out by now, you never will.";
"enc_c5e3o1_dialog_3a" = "I'm on the winning side, Shane, and I have the slugs to prove it.";
"enc_c5e3o1_dialog_4a" = "Get out of here, John. You've helped Blakk turn slugs into ghouls for the last time.";

//Encounter 4
"enc_c5e4o1_dialog_1a" = "Doombot 2.0 has launched! Doombot 2.0 is literally twice the doombot that Doombot 1.0 was.";
"enc_c5e4o1_dialog_2a" = "Is this really what you want Doombot?";
"enc_c5e4o1_dialog_3a" = "Doombot cannot help it. Doombot is programmed this way.";
"enc_c5e4o1_dialog_4a" = "Eli Shane is right. Doombot 2.0 wishes to give up this violent lifestyle.";
"enc_c5e4o1_dialog_4b" = "Doombot 2.0 will become a painter and give back to society through art.";

//Encounter 5
"enc_c5e5o1_dialog_1a" = "I thought you said you weren't Blakk's puppet.";
"enc_c5e5o1_dialog_2a" = "Blakk doubled my pay. Mista Saturday knows a good deal when he hears one.";
"enc_c5e5o1_dialog_3a" = "You have me beaten, Shane, but mark my words. I'll be back for you.";

//Encounter 6
"enc_c5e6o1_dialog_1a" = "Shorty! Glasses! Billy! Please stop this. Ghouling slugs is a huge mistake. Slugterra can't survive this.";
"enc_c5e6o1_dialog_2a" = "You're just jealous that our slugs so powerful. I'm gonna show you what a real slugslinger looks like.";

"enc_c5e6o2_dialog_1a" = "Don't worry Shorty, my Frostfang can't lose. I'll take Eli down.";
"enc_c5e6o2_dialog_2a" = "Don't you understand. You're helping Blakk destroy everything. You have to stop.";
"enc_c5e6o2_dialog_3a" = "Oof. Billy, help us!";

"enc_c5e6o3_dialog_1a" = "Billy, please... just listen to me...you are in way over your head.";
"enc_c5e6o3_dialog_2a" = "It's too late, Eli. We've made our choice.";
"enc_c5e6o3_dialog_3a" = "It's never too late. Where is Blakk?";

//Encounter 7
"enc_c5e7o1_dialog_1a" = "Slurp Munch Crunch!";
"enc_c5e7o1_dialog_2a" = "I guess there's no convincing you not to attack me.";
"enc_c5e7o1_dialog_3a" = "The only thing more delicious than a burger is defeating you.";
"enc_c5e7o1_dialog_4a" = "I have to find Blakk and end this.";

//Encounter 8
"enc_c5e8o1_dialog_1a" = "So the Shane Gang has stumbled right into our trap. Lock and load!";
"enc_c5e8o1_dialog_1b" = "Once I beat you, I'm going to have Blakk ghoul all of your slugs!";
"enc_c5e8o1_dialog_2a" = "I would never let you get your hands on my slugs.";
"enc_c5e8o1_dialog_3a" = "Lode! Get ready. You gotta beat this kid.";

"enc_c5e8o2_dialog_1a" = "Lode! You don't have to do what Locke says. Just let me heal your slugs.";
"enc_c5e8o2_dialog_2a" = "Locke may have lost but I'm gonna blow you up! Kaboom!";
"enc_c5e8o2_dialog_3a" = "Run away! Run away!";

//Encounter 9
"enc_c5e9o1_dialog_1a" = "When your father told you about monsters that go bump in the night, he was talking about me, Shane.";
"enc_c5e9o1_dialog_1b" = "I am everything you've ever been taught to fear. I am darkness. I am despair.";
"enc_c5e9o1_dialog_1c" = "I am ghouls, and ghosts, and goblins. I am your worst nightmare, Eli Shane.";
"enc_c5e9o1_dialog_2a" = "My father told me another story. One where monsters always fail because they think fear makes them strong...";
"enc_c5e9o1_dialog_2b" = "But I'm not afraid of you.";
"enc_c5e9o1_dialog_3a" = "You are beaten Nacho. Now tell me where Blakk is.";

//Encounter 10
"enc_c5e10o1_dialog_1a" = "You can fight it all you want, but I WILL rule all of Slugterra.";
"enc_c5e10o1_dialog_1b" = "I have engineered a new world order, and you, Eli Shane, will be crushed in the cogs of progress.";
"enc_c5e10o1_dialog_2a" = "You are going to be the ruler of a wasteland. Without the slugs, Slugterra won't last.";
"enc_c5e10o1_dialog_3a" = "AAARRRGGGG!";

"enc_c5e10o2_dialog_1a" = "YOU... WON'T... STOP... ME!!!";
"enc_c5e10o2_dialog_2a" = "It's over, Burpy! We did it! We stopped Blakk!";

/* End Chapter 5 */



/* Chapter 6 */


//Encounter 1
"enc_c6e1o1_dialog_1a" = "Good evening to you, Master Shane.";
"enc_c6e1o1_dialog_2a" = "Who are you? Why are you following me?";
"enc_c6e1o1_dialog_3a" = "You may think you've escaped, but the jungle holds many surprises.";

//Encounter 2

//Encounter 3
"enc_c6e3o1_dialog_1a" = "Prison break checklist. Step one: get ammo. Check! Step two: escape cell. Check!";
"enc_c6e3o1_dialog_2a" = "Graaarrraaa!";
"enc_c6e3o1_dialog_3a" = "Step three: don't get zombified!";
"enc_c6e3o1_dialog_4a" = "Urrrrrrgggg!";
"enc_c6e3o1_dialog_5a" = "Hah. Zombies might be terrifying but they have really bad aim.";

//Encounter 4
"enc_c6e4o1_dialog_1a" = "Prisoner #371. Please return to your cell. Failure to comply will result in a slugging.";
"enc_c6e4o1_dialog_2a" = "I'll take my chances. Let's show this machine what a real slugslinger looks like.";

//Encounter 5
"enc_c6e5o1_dialog_1a" = "Merrrrg!";
"enc_c6e5o1_dialog_2a" = "No thanks. Brain soup really doesn't agree with me.";
"enc_c6e5o1_dialog_3a" = "...Uuuurrrg.";
"enc_c6e5o1_dialog_4a" = "This is bad. I'd better get to the bottom of it before anyone else gets hurt.";

//Encounter 6
"enc_c6e6o1_dialog_1a" = "Hey! You aren't a zombie!";
"enc_c6e6o1_dialog_2a" = "Which is exactly why I'll be taking those slugs and that blaster";

//Encounter 7
"enc_c6e7o1_dialog_1a" = "I've been stuck in here for 23 years thanks to Will Shane. He took my slugs, my blaster and my mecha.";
"enc_c6e7o1_dialog_1b" = "Now I'm gonna get me some revenge, Shane.";

//Encounter 8
"enc_c6e8o1_dialog_1a" ="You guys look mad. Maybe you need to take a vacation.";
"enc_c6e8o1_dialog_2a" = "Mr. Saturday hired us to clean up around here. Time to take out the trash.";
"enc_c6e8o1_dialog_3a" = "This stinks. I'm taking the week off.";

"enc_c6e8o2_dialog_1a" = "We need more sick days.";

"enc_c6e8o3_dialog_1a" = "You may be good, Eli Shane, but you're never going to win this one.";
"enc_c6e8o3_dialog_2a" = "That's it! We're going on strike.";

//Encounter 9
"enc_c6e9o1_dialog_1a" = "Fool! I will crush you like a Beetle!";

//Encounter 10
"enc_c6e10o1_dialog_1a" = "You are proving to be more trouble than you are worth. But you may be useful yet, Shane.";
"enc_c6e10o1_dialog_1b" = "Any last words before I add you to my zombie army?";
"enc_c6e10o1_dialog_2a" = "You are no better than Blakk and his ghouls. Your zombie mind controlling days are over, Saturday.";
"enc_c6e10o1_dialog_3a" = "Give me back Burpy!";

/* End Chapter 6 */

/* Chapter 7 */


//Encounter 1
"enc_c7e1o1_dialog_1a" = "Shane Gang! Pull your mechas over now!";
"enc_c7e1o1_dialog_1b" = "I have to take you back to prison or Dr. Blakk is going to take away my cafeteria privileges.";
"enc_c7e1o1_dialog_2a" = "Tell your master that no cell can hold the Shane Gang.";

//Encounter 2
"enc_c7e2o1_dialog_1a" = "Whoa! Nice costume. Who are you supposed to be?";
"enc_c7e2o1_dialog_2a" = "It's no costume. I be a gentleman o' fortune.";
"enc_c7e2o1_dialog_2b" = "...A swashbuckler, a buccaneer, I practice the sweet trade.";
"enc_c7e2o1_dialog_3a" = "Oh, it's a pirate's life for me.";

//Encounter 3
"enc_c7e3o1_dialog_1a" = "Hey. I can see my house from up here!";
"enc_c7e3o1_dialog_2a" = "You are pillaging the town where you live?";
"enc_c7e3o1_dialog_3a" = "This is where the map says to go, so we had to. Otherwise we wouldn't be pirates.";
"enc_c7e3o1_dialog_4a" = "I guess I'll just go home now.";

//Encounter 4
"enc_c7e4o1_dialog_1a" = "I've been trained in seventy-five forms of slug combat. You'll never get past me!";

//Encounter 5
"enc_c7e5o1_dialog_1a" = "What be slingers doin on me ship?";
"enc_c7e5o1_dialog_1b" = "Avast! Ye be trying to perform a mutiny!";
"enc_c7e5o1_dialog_2a" = "You'll never take me alive! I'll go down with me ship.";

//Encounter 6
"enc_c7e6o1_dialog_1a" = "We found the treasure map fair and square. Now get out of the way!";
"enc_c7e6o1_dialog_2a" = "I wonder why there are so many copies of this map floating around.";

//Encounter 7
"enc_c7e7o1_dialog_1a" = "That's a pretty big cannon. How about instead of shooting at us, you just walk away.";
"enc_c7e7o1_dialog_2a" = "Kaboom!" ;
"enc_c7e7o1_dialog_3a" = "I guess that answers that!";

//Encounter 8

//Encounter 9
"enc_c7e9o1_dialog_1a" = "Gator has the secret map. Gator must get the treasure first so that Gator can retire from the pirate life.";
"enc_c7e9o1_dialog_1b" = "Gator will be victorious!";
"enc_c7e9o1_dialog_2a" = "Later Gator!";

//Encounter 10
"enc_c7e10o1_dialog_1a" = "Whoa, you are a big fella.";
"enc_c7e10o1_dialog_2a" = "Grunt.";
"enc_c7e10o1_dialog_3a" = "Grunt.";

"enc_c7e10o2_dialog_1a" = "The Captain is a bit busy pirating at the moment. Could you come back later?";

"enc_c7e10o3_dialog_1a" = "You've destroyed my ship, scattered my crew, pirated my pirate treasure and now you're gonna take me on?" ;
"enc_c7e10o3_dialog_1b" = "You've got guts. But it takes more than guts to beat a master pirate.";
"enc_c7e10o3_dialog_2a" = "No! Me treasure!" ;

/* End Chapter 7 */

/* Chapter 8 */


//Encounter 1
"enc_c8e1o1_dialog_1a" = "Shane! After my last humiliation Dr. Blakk took away my ghouls.";
"enc_c8e1o1_dialog_1b" = "I'm not going to let you beat me again.";

//Encounter 2
"enc_c8e2o1_dialog_1a" = "There are a lot of bandits in this area.";
"enc_c8e2o1_dialog_1b" = "Maybe they know something about what's going on in the Molenoid Kingdom.";
"enc_c8e2o1_dialog_2a" = "Ahh, not again!";

//Encounter 3
"enc_c8e3o1_dialog_1a" = "Let's get this over with. We've got banditing to do. You're not going to get in our way this time, Shane.";
"enc_c8e3o2_dialog_1a" = "Kablamo! Gonna explode the whole place!";

//Encounter 4
"enc_c8e4o1_dialog_1a" = "The Shane Gang is here! Sound the alarm! Spring the traps!";
"enc_c8e4o1_dialog_2a" = "Okay... So the sneaking didn't go as well as I'd hoped. Still, we made it inside! Let's get to the bottom of this.";
"enc_c8e4o2_dialog_1a" = "Even if you beat me, a thousand more slingers will take my place.";
"enc_c8e4o2_dialog_2a" = "Oh wait. Everyone ran away.";

//Encounter 5
"enc_c8e5o1_dialog_1a" = "Jeen breaks concrete slabs in half with his moustache. Jeen can bench press a train with his beard.";

//Encounter 6
"enc_c8e6o1_dialog_1a" = "Jeen is a real pushover. I think you'll find that I'm not going down so easily.";
"enc_c8e6o1_dialog_2a" = "You haven't seen anything yet. The leader of the Shame Gang is going to show you what real power is!";

//Encounter 7
"enc_c8e7o1_dialog_1a" = "Hey, you look like me...";
"enc_c8e7o1_dialog_1b" = "But less handsome!";

//Encounter 8

//Encounter 9
"enc_c8e9o1_dialog_1a" = "The Stupendous Sedo has become the King of Molenoids.";
"enc_c8e9o1_dialog_1b" = "Drop that crown you imposter!";

//Encounter 10
"enc_c8e10o1_dialog_1a" = "The Sensational Sedo cannot be defeated by a nobody like you. Sedo will win!";
"enc_c8e10o1_dialog_2a" = "Nooooo! My Mecha-Mole! You've ruined it!";

/* End Chapter 8 */

/* Chapter 9 */


//Encounter 1 - The Trips
"enc_c9e1o1_dialog_1a" = "Three times the fire power, means three times the chances to be picked.";
"enc_c9e1o2_dialog_1a" = "No. We are not leaving.";
"enc_c9e1o3_dialog_1a" = "I am the most worthy of my siblings. The Unbeatable Master will surely pick me.";

//Encounter 2

//Encounter 3 - Sid the Kid
"enc_c9e3o1_dialog_1a" = "Once the Master sees me defeat you, she will see that I am her next pupil.";
"enc_c9e3o1_dialog_2a" = "Not a chance.";

//Encounter 4 - King of Sling
"enc_c9e4o1_dialog_1a" = "Once I have unlocked the secrets of the Unbeatable Master, my kingdom will become more kingly than ever.";
"enc_c9e4o1_dialog_2a" = "No matter. A true king serves no master.";

//Encounter 5 - Trixie
"enc_c9e5o1_dialog_1a" = "Hey Trixie! Thanks for coming to support me.";
"enc_c9e5o1_dialog_2a" = "Support you? I'm here to compete. You thought all this was about you?";

//Encounter 6 - Fake Duelist
"enc_c9e6o1_dialog_1a" = "Only one challenger between me and training with the master.";
"enc_c9e6o1_dialog_1b" = "Only problem is that I have no idea who this guy is.";

//Encounter 7 - Unbeatable Master
"enc_c9e7o1_dialog_1a" = "Okay, knock knees, let's see what you got. This isn't a duel, it's an assessment.";
"enc_c9e7o1_dialog_1b" = "The judgement is mine alone.";

//Encounter 8 - Young Dr. Blakk
"enc_c9e8o1_dialog_1a" = "I spent all night callibrating my blaster. Your defeat is inevitable.";
"enc_c9e8o1_dialog_2a" = "The blaster does not make the slugslinger, Thaddius!";
"enc_c9e8o1_dialog_2b" = "You are going down!";

//Encounter 9 - Twist
"enc_c9e9o1_dialog_1a" = "You're not winning this, Twist!";
"enc_c9e9o1_dialog_2a" = "You never know, Eli.";
"enc_c9e9o1_dialog_3a" = "You're backing the wrong guy, Twist... and you know it.";

//Encounter 10 - Dr. Blakk
"enc_c9e10o1_dialog_1a" = "No.";
"enc_c9e10o1_dialog_2a" = "Excuse me.";
"enc_c9e10o1_dialog_3a" = "I said no. No more. You will never hurt another innocent person and just walk away.";

/* End Chapter 9 */

/* Chapter 10 */


//Encounter 1 - Broken Auto-Cannon
"enc_c10e1o1_dialog_1a" = "The new warden sent me to the junk heap because of you, Prisoner #371.";
"enc_c10e1o1_dialog_1b" = "I will have my re-bzzzzzzt-venge.";

//Encounter 2 - Doombot 1.0 & Doombot 2.0
"enc_c10e2o1_dialog_1a" = "Doombot 1.0? What are you doing here?";
"enc_c10e2o1_dialog_2a" = "After the Doombot program was discontinued, all Doombots were shipped here to reside.";
"enc_c10e2o1_dialog_2b" = "Doombot 1.0 initiate battle program!";
"enc_c10e2o2_dialog_1a" = "Doombot 2.0? You too?";
"enc_c10e2o2_dialog_1b" = "Doombot 2.0 initiate attack pattern 0101001110001";

//Encounter 3 - Mecha-Mole
"enc_c10e3o1_dialog_1a" = "Pew pew pew...bzzt...bzzzzzt.......pew!";
"enc_c10e3o1_dialog_1b" = "I've heard that sound before!";

//Encounter 4 - Tough Guy Gang Member #1 -
"enc_c10e4o1_dialog_1a" = "This area is off limits without Boss Ember's permission.";
"enc_c10e4o1_dialog_1b" = "Hand over all your slugs and blasters and leave Deep Storage the way you came in.";
"enc_c10e4o1_dialog_2a" = "Not gonna happen.";

//Encounter 5 - Tough Guy Gang Member #2 - Welder
"enc_c10e5o1_dialog_1a" = "Who are you?";
"enc_c10e5o1_dialog_2a" = "The Shane Gang. Maybe you've heard of us.";
"enc_c10e5o1_dialog_3a" = "Yeah, well maybe you've heard of us. We're The Tough Guys.";

//Encounter 6 - Tough Guy Gang Member #3 - Neckbrace
"enc_c10e6o1_dialog_1a" = "Parts here may be free... but the price to get 'em isn't.";
"enc_c10e6o1_dialog_1b" = "You owe Boss Ember big for this.";

//Encounter 7 - Tough Guy Gang Member #4 - Troll
"enc_c10e7o1_dialog_1a" = "Fellas, come on. That crystal is worthless to you. Just let us take it and we will get out of here.";
"enc_c10e7o1_dialog_2a" = "We'll let Boss Ember decide that.";

//Encounter 8 - Boss Ember
"enc_c10e8o1_dialog_1a" = "I'm the gatekeeper of Deep Storage. No object or customer leaves without going through me first.";
"enc_c10e8o1_dialog_1b" = "Here's the deal, Shane. You and me. One-on-one. You win, you get the Vitalis crystal. You lose, I get your blaster.";

//Encounter 9

//Encounter 10 - Angry Boss Ember
"enc_c10e10o1_dialog_1a" = "You're a cheat, Boss Ember. I won, fair and square! Give me the Vitalis crystal!";
"enc_c10e10o1_dialog_2a" = "I lied. You're not going anywhere, Shane. This is MY scrapheap.";

/* End Chapter 10 */

/* Chapter 11 */

//Encounter 1 - Glasses
"enc_c11e1o1_dialog_1a" = "Everybody reach for the sky! The Hooligang is hungry and thirsty and wants free glasses of milk and all you can eat peanuts!";

//Encounter 2 - Shorty
"enc_c11e2o1_dialog_1a" = "I was a short order cook before I became a famous villain! Now yer gonna get washed, chopped, braised and plated!";

//Encounter 3 - Billy
"enc_c11e3o1_dialog_1a" = "Not you again!";
"enc_c11e3o1_dialog_1b" = "Out of my way Eli! I'm hungry and I've been eating dried out slug pellets for three days!";
"enc_c11e3o1_dialog_2a" = "Why have you.... no...I'm not going to ask.";

//Encounter 4 - Jeen
"enc_c11e4o1_dialog_1a" = "What are you guys doing here? Are you working for the Hooligang?";
"enc_c11e4o1_dialog_1b" = "The Shame Gang wants revenge! Jeen's gonna bench press Eli Shane with his sideburns!";
"enc_c11e4o1_dialog_1c" = "Are you sure you aren't here with the Hooligang? Because they were just here!";

//Encounter 5 - Trapsie
"enc_c11e5o1_dialog_1a" = "You might be a match for Jeen's sideburns but you're no match for me!";

//Encounter 6 - Alias
"enc_c11e6o1_dialog_1a" = "Well if it isn't my less handsome twin! Sedo's out! I'm the leader of the Shame Gang now and I want revenge!";

//Encounter 7 - Welder Walter & Lil Stevie
"enc_c11e7o1_dialog_1a" = "The Tough Guys? Why aren't you back working with Boss Ember?";
"enc_c11e7o1_dialog_1b" = "The Tough Guys were fired for not being tough enough! Now we're looking for trouble while also looking for new jobs!";
"enc_c11e7o1_dialog_2a" = "Hey Eli! Do you guys have an opening in the Shane Gang? Here's my villain resume!";

//Encounter 8 - Mongo
"enc_c11e8o1_dialog_1a" = "I'm doin' volunteer work now! For Free!";
"enc_c11e8o1_dialog_2a" = "I volunteer to beat Eli in a duel for free! Right Now!";

//Encounter 9 - Straggus
"enc_c11e9o1_dialog_1a" = "I can't afford new light bulbs for my villain helmet! That makes me so mad!";

//Encounter 10 - Billy, Alias & Straggus
"enc_c11e10o1_dialog_1a" = "The Hooligang, the Shame Gang and the Tough Guys? Why are you all here?";
"enc_c11e10o1_dialog_1b" = "Some of us are hungry, some of us are handsome and want revenge and some of us need new jobs! When we work together nothing can stop us!";
"enc_c11e10o2_dialog_2a" = "My quest for revenge has introduced me to some new villainous friends!";
"enc_c11e10o3_dialog_3a" = "I have learned that it is easier to complete villainous tasks with the help of good friends!";
"enc_c11e10o3_dialog_4a" = "Take it outside, fellas!";
"enc_c11e10o3_dialog_5a" = "I can't believe we lost, even with the villainous power of friendship!";

/* End Chapter 11 */

/* Chapter 12 */


//Encounter 1 - Blakk Soldier & John Bull
"enc_c12e1o1_dialog_1a" = "Halt ruffian! You're under arrest in the name of Dr. Thadeus Blakk!";
"enc_c12e1o1_dialog_2a" = "Arrested? What are the charges?";
"enc_c12e1o1_dialog_1b" = "Slinging without a license!";
"enc_c12e1o1_dialog_3a" = "You got nowhere to run, Shane! There is a big chasm behind you!";

//Encounter 2 - Nacho
"enc_c12e2o1_dialog_1a" = "Hand over your blaster and we will go easy on you!";
"enc_c12e2o1_dialog_2a" = "I'll pass on that offer!";
"enc_c12e2o1_dialog_3a" = "Don't look back, Eli! It's a long way down!";
"enc_c12e2o2_dialog_4a" = "Are you scared of heights, Nacho? Because I'm not!";

//Encounter 3 - Darkbane Soldier 1
"enc_c12e3o1_dialog_1a" = "Woah! What are you supposed to be?";
"enc_c12e3o1_dialog_1b" = "Wraaaooorrrr!!!!!";
"enc_c12e3o1_dialog_2a" = "Watch it with the fireballs!";

//Encounter 4 - Darkbane Soldier 2
"enc_c12e4o1_dialog_1a" = "Another one! Where are these things coming from?";

//Encounter 5 - Darkbane Soldier 3
"enc_c12e5o1_dialog_1a" = "Wraooor!!!";
"enc_c12e5o1_dialog_2b" = "Come on Burpy! We need to get to the bottom of this!";

//Encounter 6 - Shadow Clan Protector
"enc_c12e6o1_dialog_1a" = "Halt! This is sacred ground and you shall not pass!";
"enc_c12e6o1_dialog_2a" = "Wait a minute! I'm Eli Shane!";
"enc_c12e6o1_dialog_3a" = "The Slug Gate is faltering! If you are truly the Shane then you must protect the Slug Gate and stop the Darkbane!";
"enc_c12e6o1_dialog_4a" = "I don't know who these Darkbane are but I'll help you!";
"enc_c12e6o1_dialog_3b" = "The Deep Caverns are full of dark and corrupting energy! Keep your wits about you, young Shane!";

//Encounter 7 - Prison Door
"enc_c12e7o1_dialog_1a" = "Ok Burpy! I hope you know what you're doing. Let's break down this door!";

//Encounter 8 - Prison Guards
"enc_c12e8o1_dialog_1a" = "The prisoner has escaped! Sound the alarm!";
"enc_c12e8o1_dialog_2a" = "Your ghouls won't save you, puny human!";
"enc_c12e8o1_dialog_3a" = "Come on Burpy! We need to get out of here and fast!";

//Encounter 9 - Prison Warden
"enc_c12e9o1_dialog_1a" = "I wrote a poem! It's called 'Puny human, get back in your cell!' Would you like to hear it?";
"enc_c12e9o1_dialog_2a" = "Um...ok?";
"enc_c12e9o1_dialog_1b" = "Fire is red, rocks are black! Puny human, get back in your cell!";
"enc_c12e9o1_dialog_2b" = "You really have a way with words!";

//Encounter 10 - Darkbane Nacho
"enc_c12e10o1_dialog_1a" = "You surprise me, Shane! I never thought you would ghoul your own slugs just to save yourself!";
"enc_c12e10o1_dialog_2a" = "You have left me no choice! We can't let you invade Slugterra!";
"enc_c12e10o1_dialog_3a" = "Do you forget where you are? You are lost in the heart of the Deep Caverns! You are too late, Eli Shane!";
"enc_c12e10o1_dialog_3b" = "The Behemoth will shatter your precious Slug Gate and the Darkbane will reclaim their rightful place in Slugterra!";

/* End Chapter 12 */

/* Chapter 13 */


//Encounter 1 - Darkbane 1
"enc_c13e1o1_dialog_1a" = "So much for a quiet escape!";

//Encounter 2 - Darkbane 2
"enc_c13e2o1_dialog_1a" = "For the honor of the Darkbane!";

//Encounter 3 - Darkbane 3
"enc_c13e3o1_dialog_1a" = "You cannot escape!";

//Encounter 4 - Prison Warden
"enc_c13e4o1_dialog_1a" = "I wrote another poem!";
"enc_c13e4o1_dialog_2a" = "Why am I not surprised?";
"enc_c13e4o1_dialog_1b" = "Puny human, you are small! Puny human, not so tall! Get back in your cell!";
"enc_c13e4o1_dialog_2b" = "That was worse than your last poem!";

//Encounter 5 - Bonus Round - Brimstone's Throne

//Encounter 6 - Darkbane Elite 1 & 2
"enc_c13e6o1_dialog_1a" = "Hey fellas!";
"enc_c13e6o1_dialog_2a" = "You are no match for the Darkbane Elite!";
"enc_c13e6o1_dialog_3a" = "Kneel before the Darkbane and your end will be swift!";

//Encounter 7 - Darkbane Nacho
"enc_c13e7o1_dialog_1a" = "You are no match for the magic of the Darkbane!";
"enc_c13e7o1_dialog_2a" = "My slugs are more than a match for you! They are the true guardians of Slugterra!";

//Encounter 8 - Angry Nacho
"enc_c13e8o1_dialog_1a" = "Nacho! What is going on? You're a Darkbane?";
"enc_c13e8o1_dialog_2a" = "So you know my secret, something even Dr. Blakk doesn't know.";
"enc_c13e8o1_dialog_1b" = "I won't let you leave, Eli!";

//Encounter 9 - Behemoth
"enc_c13e9o1_dialog_1a" = "Woah! You're a big fella!";
"enc_c13e9o1_dialog_2a" = "Guarrrrrhhh!!!!!";
"enc_c13e9o1_dialog_3a" = "The bigger they are, the harder they fall!";

//Encounter 10 - Brimstone
"enc_c13e10o1_dialog_1a" = "The Darkbane will retake their rightful place as the rulers of Slugterra! It is our destiny!";
"enc_c13e10o1_dialog_2a" = "I won't let you past!";
"enc_c13e10o1_dialog_1b" = "I will lay waste to this cavern! I will turn this gate into a flaming crater!";
"enc_c13e10o1_dialog_3a" = "Noooooo!!!! I have waited too long to fail!";
"enc_c13e10o1_dialog_4a" = "Burpy! Send Brimstone back where he came from!";

/* End Chapter 13 */

/* Chapter 14 */


//Encounter 1 - Pronto, Kord and Trixie
"enc_c14e1o1_dialog_1a" = "Are you ready to practice Pronto?";
"enc_c14e1o1_dialog_1b" = "Pronto is always ready for a duel! Did you know that Pronto is a famous slugslinger among the molenoids?";
"enc_c14e1o2_dialog_2a" = "Gotta stay sharp Eli! Slugslingers need to work out if they are gonna stay on top!";
"enc_c14e1o2_dialog_2b" = "Bring it on!";
"enc_c14e1o3_dialog_3a" = "Eli you look tired! It should make you easier to beat in a duel!";
"enc_c14e1o3_dialog_3b" = "You know what? I am feeling a little sleepy.";

//Encounter 2 - Dr.Blakk
"enc_c14e2o1_dialog_1a" = "Blakk! What are you doing here? You don't take part in slugslinging tournaments!";
"enc_c14e2o1_dialog_1b" = "I've never seen you before in my life! Prepare to duel stranger!";

//Encounter 3 - Spirex
"enc_c14e3o1_dialog_1a" = "Eli Shane! You are tangled in your dreams like a fly in a web!";

//Encounter 4 - Eli
"enc_c14e4o1_dialog_1a" = "You... you're me! What's going on here?";
"enc_c14e4o1_dialog_2a" = "Hold on a minute! I'm the real Eli Shane!";

//Encounter 5 - Young Blakk
"enc_c14e5o1_dialog_1a" = "You look very familiar! You look like.... a young Dr Blakk!";

//Encounter 6 - Behemoth
"enc_c14e6o1_dialog_1a" = "Woah big fella! How did you get in the tournament? You don't even have a blaster!";
"enc_c14e6o1_dialog_2a" = "Wraaaaoooorrrrr!";

//Encounter 7 - Angry Blakk
"enc_c14e7o1_dialog_1a" = "You again! Why do you insist on getting in my way?";
"enc_c14e7o1_dialog_2a" = "You always did have a bad temper!";

//Encounter 8 - Unbeatable Master
"enc_c14e8o1_dialog_1a" = "Life is but an illusion Eli! True wisdom can be found in dreams. Seek out the one you yearn to find!";
"enc_c14e8o1_dialog_2a" = "Wait! How will I know when I find this person?";
"enc_c14e8o1_dialog_2b" = "Your heart knows what your mind has yet to learn.";

//Encounter 9 - Gat Blakk
"enc_c14e9o1_dialog_1a" = "That doesn't look like a regulation blaster!";
"enc_c14e9o1_dialog_2a" = "This might be your dream Eli Shane, but I will have my revenge! Prepare to be blasted!";

//Encounter 10 - Will Shane
"enc_c14e10o1_dialog_1a" = "Eli! You have confronted so many dangers on your journeys. Let me see what you have learned.";
"enc_c14e10o1_dialog_2a" = "Dad! You're alive! I have looked everywhere for you....";
"enc_c14e10o1_dialog_3a" = "I am so proud of you son. You have become a truly great Shane.";
"enc_c14e10o1_dialog_3b" = "Come back with me! I have so many things I want to ask you, so many questions.";
"enc_c14e10o1_dialog_3c" = "Eli, you are the Shane now! We will meet again, when all seems darkest. Goodbye son.";

/* End Chapter 14 */

/* Chapter 15 */


//Encounter 1 - Dr.Blakk
"enc_c15e1o1_dialog_1a" = "I see you got my message!";
"enc_c15e1o2_dialog_1a" = "Why did you call me here, Blakk?";
"enc_c15e1o1_dialog_2a" = "This is a very important place Eli. Do you know why? Let me tell you a story.";

//Encounter 2 - Angry Miner
"enc_c15e2o1_dialog_1a" = "This is Viggo Dare's mine and new grunts gotta learn their place!";
"enc_c15e2o2_dialog_1b" = "I don't want any trouble!";

//Encounter 3 - Foreman
"enc_c15e3o1_dialog_1a" = "Let me pass!";
"enc_c15e3o2_dialog_1a" = "Can't just walk out of here. You belong to Viggo Dare now!";

//Encounter 4 - The Heavy, The Rat
"enc_c15e4o1_dialog_1a" = "Looky here! It's the runaway!";
"enc_c15e4o1_dialog_2a" = "We's gotta fetch you back to the mines! Boss's orders!";

//Encounter 5 - Young Will Shane
"enc_c15e5o1_dialog_1a" = "Halt! Are you the one responsible for roughing up two citizens?";
"enc_c15e5o2_dialog_1a" = "What? Those are Viggo Dare's men. They attacked me!";
"enc_c15e5o2_dialog_1b" = "I am the Shane! You'll think twice before making trouble in this cavern again!";

//Encounter 6 - Viggo, Dare, The Rat
"enc_c15e6o1_dialog_1a" = "You again! Boss ain't gonna be happy!";
"enc_c15e6o1_dialog_1b" = "You have caused me a lot of trouble! Now get back to those mines before I drag you down there!";
"enc_c15e6o2_dialog_1a" = "I am tired of getting pushed around! This is my cavern now! Drop your blaster and I will let you walk out of here.";
"enc_c15e6o3_dialog_1a" = "Your men are now my men! Your mines are now my mines! This cavern is now my cavern and you are trespassing!";
"enc_c15e6o3_dialog_1b" = "Now run!";

//Encounter 7 - Will Shane
"enc_c15e7o1_dialog_1a" = "Blakk! I won't let you force these people off their land just so you can run a train through here!";
"enc_c15e7o2_dialog_2a" = "You can't stand in the way of progress, Shane! The Slugterra Express is the way of the future!";
"enc_c15e7o1_dialog_3a" = "You may have beaten me today but you aren't above the law!";
"enc_c15e7o2_dialog_3a" = "That's where you are wrong! The rich and powerful make the laws! I am the law!";
"enc_c15e7o1_dialog_4a" = "You are wrong. Your heart is twisted and your slugs don't want to fight for you. I can see it in their eyes!";
"enc_c15e7o2_dialog_4a" = "All will bow to my will, even slugs! They are just tools to help me build my empire!";

//Encounter 8 - Brimestone
"enc_c15e8o1_dialog_1a" = "Where am I?";
"enc_c15e8o1_dialog_2a" = "Power is the only currency here!";
"enc_c15e8o1_dialog_2b" = "You have earned your place! Let me offer you something in return.";

//Encounter 10 - Will Shane
"enc_c15e10o1_dialog_1a" = "Why did you call me here, Blakk?";
"enc_c15e10o2_dialog_2a" = "You have been a thorn in my side long enough! I have power that you can only dream of!";
"enc_c15e10o1_dialog_3a" = "What have you done?";
"enc_c15e10o2_dialog_3a" = "I have bent the slugs to my will! I have unleashed their true power!";

//Encounter 11 - Dr.Blakk
"enc_c15e11o1_dialog_1a" = "So you see, Eli, you are standing on the place where I defeated Will Shane.";
"enc_c15e11o1_dialog_2a" = "What have you done with my father!?!?!";
"enc_c15e11o1_dialog_3a" = "He has disappeared into the darkness, not even a shadow remaining!";
"enc_c15e11o1_dialog_3b" = "But our story isn't finished, Eli Shane. My plans have all come together and soon all will become clear!";
"enc_c15e11o1_dialog_3c" = "Ah, I can hear them coming now!";

/* End Chapter 15 */

/* Chapter 16 */


//Encounter 1 - Delta Operator
"enc_c16e1o1_dialog_1a" = "Get back! These people haven't done anything!";
"enc_c16e1o1_dialog_2a" = "Alpha Force engaging enemy!";
"enc_c16e1o2_dialog_1a" = "Fall back! Echelon formation!";

//Encounter 2 - Doombot 1.0
"enc_c16e2o1_dialog_1a" = "10011011010101001";

//Encounter 3 - Mr. Orange
"enc_c16e3o1_dialog_1a" = "Delta Force engaging!";

//Encounter 4 - Locke and Load
"enc_c16e4o1_dialog_1a" = "What are you doing here Locke?";
"enc_c16e4o1_dialog_2a" = "Boss said go make a diversion! So we're diversioning!";
"enc_c16e4o2_dialog_1a" = "Dr. Blakk don't want you to pay any attention to him. He's got a plan and don't want you to know about it!";
"enc_c16e4o2_dialog_2a" = "Thanks! I won't tell anyone!";

//Encounter 5 - Darkbane Drek and Darkbane Hartag
"enc_c16e5o1_dialog_1a" = "Darkbane! Where are you taking them?";
"enc_c16e5o2_dialog_1a" = "Grahhh! Get in the wagon!";
"enc_c16e5o2_dialog_1b" = "Gruuugh!";

//Encounter 6 - Prison Warden
"enc_c16e6o1_dialog_1a" = "I wrote a poem for you!";
"enc_c16e6o1_dialog_1b" = "Oh, here we go...";
"enc_c16e6o2_dialog_1a" = "Fire, fire burning bright, in the caverns of the night; What Darkbane hand or eye, could frame thy burning symmetry?";
"enc_c16e6o3_dialog_1a" = "Wow, you are getting much better!";

//Encounter 7 - Nacho
"enc_c16e7o1_dialog_1a" = "A dark wave approaches! The shadow is crossing your path, Shane! New alliances have formed!";
"enc_c16e7o2_dialog_2a" = "I won't let you hurt these people!";

//Encounter 8 - Bonus Round - Prison Wagon

//Encounter 9 - Titan
"enc_c16e10o1_dialog_1a" = "Where's a can opener when you need one?";

//Encounter 10 - Angry Nacho
"enc_c16e11o1_dialog_1a" = "You think you can win? The Darkbane will reclaim their lands.";
"enc_c16e11o1_dialog_2a" = "I've stopped you before, I can do it again.";
"enc_c16e11o1_dialog_3a"= "An army waits to flood Slugterra in darkness!";
"enc_c16e11o1_dialog_3b" = "Where is this army?";
"enc_c16e11o1_dialog_3c" = "Enjoy your last days of peace. Even now Dr. Blakk prepares the way!";

