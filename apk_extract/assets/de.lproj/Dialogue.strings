"enc_c17e6o1_dialog_1a" = "Halt! This is a restricted area!";
"enc_c17e6o2_dialog_1a" = "Code Red! Intruder on level three!";

//Encounter 7 - Dr Blakk
"enc_c17e7o1_dialog_1a" = "Greetings Shane! It is only fitting that you are here to witness the fall of Slugterra!";
"enc_c17e7o1_dialog_2a" = "What have you done Blakk?";
"enc_c17e7o1_dialog_3a" = "Come and meet your destiny!";

//Encounter 8 - Darkbane Elite
"enc_c17e8o1_dialog_1a" = "Noooooooo!";
"enc_c17e8o1_dialog_2a" = "Forward to victory!";
"enc_c17e8o1_dialog_3a" = "We will reclaim what's ours!";
"enc_c17e8o1_dialog_4a" = "Finally! After a millennia the Darkbane have returned home! Cower before your new masters!";

//Encounter 9 - Dr. Blakk
"enc_c17e9o1_dialog_1a" = "No... no... NO...ARRRGHHH!!!...";
"enc_c17e9o1_dialog_2a" = "This is the last time Blakk! No more!";
"enc_c17e9o1_dialog_3a" = "You have ruined EVERYTHING!!!";
"enc_c17e9o1_dialog_4a" = "For my father, for my friends, for the slugs, for all of Slugterra...... NO MORE!!!";

