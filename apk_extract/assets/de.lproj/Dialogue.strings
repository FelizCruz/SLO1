"enc_c3e1o1_dialog_2a" = "She was in the wrong place at the wrong time. Now back off or we'll do the same to you.";
"enc_c3e1o1_dialog_3a" = "You're better than I thought. But you're still too late. Retreat!";

//Encounter 2
"enc_c3e2o1_dialog_1a" = "Eli Shane! You made us look like fools! Play with fire you're gonna get burned!";

"enc_c3e2o2_dialog_1a" = "Freeze!";
"enc_c3e2o2_dialog_2a" = "Don't you know when to quit?";

