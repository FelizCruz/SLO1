/* Chapter 17 */


//Encounter 1 - Red Hook
"enc_c17e1o1_dialog_1a" = "Red Hook... you look different...";
"enc_c17e1o2_dialog_1a" = "Draw your blaster Eli!";
"enc_c17e1o3_dialog_1a" = "!?!?!?!";
"enc_c17e1o1_dialog_2a" = "Well now you know... It's a trap! You shouldn't have come here.";
"enc_c17e1o2_dialog_2a" = "What have you done with Red Hook?";
"enc_c17e1o1_dialog_3a" = "Eli, thank goodness you came! Dr. Blakk tried to have me kidnapped. He is working on something terrible, a machine...";
"enc_c17e1o2_dialog_3a" = "Whatever it is it can't be good!";
"enc_c17e1o3_dialog_3a" = "You need to go to the Citadel! You need to stop Blakk!";

//Encounter 2 - Darkbane Guards
"enc_c17e2o1_dialog_1a" = "Darkbane! Here!?!?!";
"enc_c17e2o2_dialog_1a" = "Dr. Blakk ordered us to work with the Darkbane... but they are kinda scary!";
"enc_c17e2o3_dialog_1a" = "Graaaarrrrrrrrr!!!!!!!";

//Encounter 3 - Nacho
"enc_c17e3o1_dialog_1a" = "I knew you would come, Eli! Can't stop being the hero.";
"enc_c17e3o2_dialog_1a" = "Out of my way, Nacho!";

