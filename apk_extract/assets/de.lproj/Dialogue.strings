/* Chapter 2 */


//Encounter 1
"enc_c2e1o1_dialog_1a" = "Check it out Burpy, our first tournament.";
"enc_c2e1o1_dialog_2a" = "You'll need more than one fire slug to beat me, kid!";
"enc_c2e1o1_dialog_3a" = "I'm not just a kid, I'm Eli Shane!";
"enc_c2e1o1_dialog_4a" = "I can't believe I lost to a kid.";

//Encounter 2
"enc_c2e2o1_dialog_1a" = "My Frostcrawler is going to put the freeze on you!";
"enc_c2e2o1_dialog_2a" = "We got this Burpy!";
"enc_c2e2o1_dialog_3a" = "I give up! Guess that means you win my Frostcrawler!";
"enc_c2e2o1_dialog_4a" = "Hey little guy. How do you feel about the name Chiller?";

//Encounter 3
"enc_c2e3o1_dialog_1a" = "Hey there! What is the video camera for?";
"enc_c2e3o1_dialog_2a" = "I'm making a documentary called 'Trixie Sting: The Girl Who Beat Eli Shane'.";
"enc_c2e3o1_dialog_3a" = "The title needs a little work.";
"enc_c2e3o1_dialog_4a" = "You've got some moves! How'd you like to join the Shane Gang?";
"enc_c2e3o1_dialog_5a" = "Fight for justice with the new Shane? I'm in!";

//Encounter 4
"enc_c2e4o1_dialog_1a" = "How well do you conduct electricity, Eli Shane?";
"enc_c2e4o1_dialog_2a" = "Why do you ask?";
"enc_c2e4o1_dialog_3a" = "CHARGE!!!!";
"enc_c2e4o1_dialog_4a" = "I think it's time to replace your batteries...";

//Encounter 5
"enc_c2e5o1_dialog_1a" = "Don't worry, you'll have plenty of time to get my autograph after I defeat you!";
"enc_c2e5o1_dialog_2a" = "Impossible! No one beats the King of Sling!";
"enc_c2e5o1_dialog_3a" = "Maybe you should just call yourself the Prince of Sling.";

//Encounter 6
"enc_c2e6o1_dialog_1a" = "Hey Pronto! How are you?";
"enc_c2e6o1_dialog_2a" = "Do not try to distract Pronto with friendly words!";

//Encounter 7
"enc_c2e7o1_dialog_1a" = "We've got three good reasons you'll never get past this round.";
"enc_c2e7o1_dialog_2a" = "One down...";

"enc_c2e7o2_dialog_1a" = "You really don't fight fair!";
"enc_c2e7o2_dialog_2a" = "I only follow two rules. Win every match and never ever lose.";

"enc_c2e7o3_dialog_1a" = "And one to go...";
"enc_c2e7o3_dialog_2a" = "No fair. You didn't tell us that three is your lucky number.";
"enc_c2e7o3_dialog_3a" = "We did it Burpy! We are in the finals!";
"enc_c2e7o3_dialog_3b" = "I knew we could do it!";

//Encounter 8
"enc_c2e8o1_dialog_1a" = "Hey Eli. You're doin' great so far, but be careful.";
"enc_c2e8o1_dialog_1b" = "I've been hearin' rumours that someone has put a contract out on you.";
"enc_c2e8o1_dialog_2a" = "Why would anyone be after me?";
"enc_c2e8o1_dialog_3a" = "Not everyone in Slugterra was a fan of your father. Someone must not want to see a new Shane Gang!";
"enc_c2e8o1_dialog_4a" = "Remember what I said! Watch your back!";

//Encounter 9

//Encounter 10
"enc_c2e10o1_dialog_1a" = "I'm afraid you aren't going to make it to the final round of the tournament, Eli Shane.";
"enc_c2e10o1_dialog_1b" = "Billy says to crawl back under the rock you've been hiding under all these years or else...";
"enc_c2e10o1_dialog_2a" = "You'll pay for this, Shane.";
"enc_c2e10o1_dialog_3a" = "Wait! Who is Billy? And why is he after me? Come back here!";

//Encounter 11
"enc_c2e11o1_dialog_1a" = "Prepare yourself. My employer wants you out of the way! It's nothing personal.";
"enc_c2e11o1_dialog_2a" = "You are working for Billy too? Where is he?";
"enc_c2e11o1_dialog_3a" = "You have a lot to learn about this place, Shane... And I'm going to be your first teacher.";
"enc_c2e11o1_dialog_4a" = "You may have won the tournament, but you have no idea what's coming your way.";

/* End Chapter 2 */



/* Chapter 3 */

//Encounter 1
