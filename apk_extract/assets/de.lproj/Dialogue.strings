"enc_c3e4o1_dialog_1a" = "Oh great. Another one of Billy's henchmen.";
"enc_c3e4o1_dialog_2a" = "I don't work for Billy! I work for Doctor... Never mind who I work for.";
"enc_c3e4o1_dialog_2b" = "It’s not going to matter in a minute when I take you out.";
"enc_c3e4o1_dialog_3a" = "Uh oh. The boss isn't going to be happy about this.";

