/* Chapter 1 */

//Encounter 1
"enc_c1e1o1_dialog_1a" = "Super ! Un troll des cavernes. J'ai toujours rêvé d'en rencontrer un !";
"enc_c1e1o1_dialog_2a" = "Je m'appelle Kord Zane. Tu viens d'ailleurs, c'est bien ça ?";
"enc_c1e1o1_dialog_2b" = "Je ferais bien de t'apprendre à te défendre. Regarde la grille de tuiles en dessous.";
"enc_c1e1o1_dialog_3a" = "Pour déplacer une tuile, touche-la et emmène-la sur une tuile adjacente.";
"enc_c1e1o1_dialog_4a" = "Bien joué, gamin. Ça ira.";
"enc_c1e1o1_dialog_5a" = "OK, Eli. Maintenant je vais te montrer comment associer des tuiles.";
"enc_c1e1o1_dialog_6a" = "Voyons maintenant si tu peux faire une série de trois tuiles blaster.";
"enc_c1e1o1_dialog_7a" = "Waouh ! C'était ton premier tir au blaster ? Même pas en rêve, tu aurais dû m'atteindre.";
"enc_c1e1o1_dialog_7b" = "Je parie que tu n'es pas capable de le refaire.";
"enc_c1e1o1_dialog_8a" = "Bouge les tuiles blaster pour faire une autre série !";
"enc_c1e1o1_dialog_9a" = "Aïe ! D'accord, t'es pas mauvais au tir... mais il n'y a pas que toi qui possède un blaster ! Faisons un duel !";
"enc_c1e1o1_dialog_10a" = "Oh ! Aïeuh ! Ouf... Pourquoi tu as fait ça ? Oh! C'est vrai, je t'ai dit de le faire...";

//Encounter 2
"enc_c1e2o1_dialog_1a" = "Super, gamin ! Prochaine étape : les soins.";
"enc_c1e2o1_dialog_2a" = "Fais une série de trois tuiles de santé (vertes) pour remplir ta barre de santé.";
"enc_c1e2o1_dialog_3a" = "Ça va mieux ? Bien !";
"enc_c1e2o1_dialog_4a" = "Pardon, mon blaster est sensible. Il faudrait que tu te soignes encore.";
"enc_c1e2o1_dialog_5a" = "Fais une série avec ces quatre tuiles de santé.";
"enc_c1e2o1_dialog_6a" = "Le mieux est d'associer un maximum de tuiles en un seul coup.";
"enc_c1e2o1_dialog_6b" = "Voyons maintenant combien de temps tu résistes à un duel.";
"enc_c1e2o1_dialog_7a" = "Mince. J'ai bien failli gagner.";
"enc_c1e2o1_dialog_8a" = "À la base, tu n'étais pas censé me former ?";
"enc_c1e2o1_dialog_9a" = "Bon d'accord... C'était un test... et tu l'as réussi !";

//Encounter 3
"enc_c1e3o1_dialog_1a" = "Hé ! C'est un slug Inferna que tu as là ?";
"enc_c1e3o1_dialog_2a" = "Il s'appelle Burpy. Il est génial.";
"enc_c1e3o1_dialog_3a" = "Les slugs Inferna se transforment en de puissantes créatures de feu.";
"enc_c1e3o1_dialog_4a" = "Burpy aimerait s'entraîner à la transformation.";
"enc_c1e3o1_dialog_5a" = "Pour donner plus de puissance aux attaques de Burpy, fais des séries avec des tuiles de feu !";
"enc_c1e3o1_dialog_6a" = "Continue ! Il a encore besoin de puissance.";
"enc_c1e3o1_dialog_7a" = "Une série de 5 tuiles de feu donne un niveau de charge à Burpy.";
"enc_c1e3o1_dialog_8a" = "Maintenant que Burpy est chargé, touche ton slug pour lancer sa nouvelle attaque !";
"enc_c1e3o1_dialog_9a" = "Aïe aïe aïe aïe aïe. OK, je crois que tu as pigé le truc. Maintenant, duel !";
"enc_c1e3o1_dialog_10a" = "Aïeuh ! La prochaine fois, évite de mettre le feu à mes fringues !";
"enc_c1e3o1_dialog_10b" = "À mon avis, tu es prêt pour ton premier duel ! PRONTO !";

/* End Chapter 1 */

