/* Chapter 1 */

//Encounter 1
"enc_c1e1o1_dialog_1a" = "Cool! A cave troll. I've always wanted to meet a cave troll!";
"enc_c1e1o1_dialog_2a" = "I'm Kord Zane. You're not from around here are you?";
"enc_c1e1o1_dialog_2b" = "I had better teach you how to defend yourself. Watch the tile grid below.";
"enc_c1e1o1_dialog_3a" = "Try moving tiles around by touching a tile and dragging it to an adjacent tile.";
"enc_c1e1o1_dialog_4a" = "Good job, kid. That's enough.";
"enc_c1e1o1_dialog_5a" = "Okay Eli, I'll show you how to match tiles now.";
"enc_c1e1o1_dialog_6a" = "Now see if you can match three blaster tiles.";
"enc_c1e1o1_dialog_7a" = "Oof! That was your first blaster shot ever!?! There is no way that you should have been able to hit me.";
"enc_c1e1o1_dialog_7b" = "I bet you can't do it again.";
"enc_c1e1o1_dialog_8a" = "Move the blaster tiles to make another match!";
"enc_c1e1o1_dialog_9a" = "Ouch! Okay, so you're pretty good at shooting... but you're not the only one with a blaster! Let's duel!";
"enc_c1e1o1_dialog_10a" = "Ooh! Ow! Oof! What did you do that for? Oh right, I told you to...";

//Encounter 2
"enc_c1e2o1_dialog_1a" = "Great job kid! Next step: healing.";
"enc_c1e2o1_dialog_2a" = "Match three green health tiles to restore your health bar.";
"enc_c1e2o1_dialog_3a" = "Feeling better? Good!";
"enc_c1e2o1_dialog_4a" = "Sorry, my blaster is a little touchy. You'd better heal up again.";
"enc_c1e2o1_dialog_5a" = "Try matchin' those four health tiles.";
"enc_c1e2o1_dialog_6a" = "The more tiles you can match in one move, the better.";
"enc_c1e2o1_dialog_6b" = "Now let's see how long you can keep yourself in the duel.";
"enc_c1e2o1_dialog_7a" = "Darn. I was so close to winning.";
"enc_c1e2o1_dialog_8a" = "Aren't you supposed to be teaching me?";
"enc_c1e2o1_dialog_9a" = "Oh, right. Uh... that was a test... and you passed!";

//Encounter 3
"enc_c1e3o1_dialog_1a" = "Dude! Is that an Infurnus slug you have there?";
"enc_c1e3o1_dialog_2a" = "His name's Burpy. He's awesome.";
"enc_c1e3o1_dialog_3a" = "Infurnus slugs transform into powerful fire creatures.";
"enc_c1e3o1_dialog_4a" = "Burpy says he wants to practice transforming.";
"enc_c1e3o1_dialog_5a" = "Try matchin' some fire tiles to power up Burpy's attack!";
"enc_c1e3o1_dialog_6a" = "Keep goin'! He needs more juice.";
"enc_c1e3o1_dialog_7a" = "Matchin' five fire tiles at once will charge Burpy one level.";
"enc_c1e3o1_dialog_8a" = "Now that Burpy is powered up, tap on your slug to unleash his new attack!";
"enc_c1e3o1_dialog_9a" = "Ow ow ow ow ow. Okay. I think you get the hang of it. Duel!";
"enc_c1e3o1_dialog_10a" = "Youch! Next time try not to light my pants on fire!";
"enc_c1e3o1_dialog_10b" = "I think you might be ready for your first real duel! PRONTO!!!!!!";

/* End Chapter 1 */

