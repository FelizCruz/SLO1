"name_cavern6_name" = "";
//Encounter 1
"enc_c1e1o1_dialog_1a" = "Круто! Пещерный тролль. Всегда мечтал встретиться с таким.";
"enc_c1e1o1_dialog_2a" = "Я — Корд Зейн. А ты не местный, да?";
"enc_c1e1o1_dialog_2b" = "Мне следовало бы научить тебя защищаться. Смотри на сетку плиток внизу.";
"enc_c1e1o1_dialog_3a" = "Перемещай плитки, касаясь их и перетаскивая на смежные плитки.";
"enc_c1e1o1_dialog_4a" = "Молодец! Ну все, хватит.";
"enc_c1e1o1_dialog_5a" = "Теперь, Элай, я покажу тебе, как подбирать плитки.";
"enc_c1e1o1_dialog_6a" = "Посмотрим, сможешь ли ты подобрать три одинаковых плитки бластера.";
"enc_c1e1o1_dialog_7a" = "Ты что, никогда бластер в руках не держал?! Да ты ни за что бы в меня не попал.";
"enc_c1e1o1_dialog_7b" = "Могу поспорить, ты снова промажешь.";
"enc_c1e1o1_dialog_8a" = "Перемести плитки бластера, чтобы подобрать их.";
"enc_c1e1o1_dialog_9a" = "Ой! Ну ладно, ты неплохой стрелок... но бластер есть не только у тебя. Сразимся на поединке!";
"enc_c1e1o1_dialog_10a" = "Ай! Ой! Ой! За что ты меня так? А, точно, я сам напросился...";

/* End Cavern 6 */

/* Cavern 7 */

/*Cavern 7*/
"name_cavern7_name" = "";
//Encounter 1
"enc_cv7e1o1_dialog_1a" = "";
//Encounter 2
"enc_c1e2o1_dialog_1a" = "Молодчина! Следующий шаг: исцеление.";
"enc_c1e2o1_dialog_2a" = "Подбери три зеленые плитки, чтобы восстановить здоровье.";
"enc_c1e2o1_dialog_3a" = "Уже получше? Хорошо.";
"enc_c1e2o1_dialog_4a" = "Извини, мой бластер слишком чувствителен. Поправь-ка здоровье еще раз.";
"enc_c1e2o1_dialog_5a" = "Подбери эти четыре плитки здоровья.";
"enc_c1e2o1_dialog_6a" = "Чем больше плиток ты подберешь за один ход, тем лучше.";
"enc_c1e2o1_dialog_6b" = "Теперь посмотрим, как долго ты продержишься на поединке.";
"enc_c1e2o1_dialog_7a" = "Черт. Победа была так близко.";
"enc_c1e2o1_dialog_8a" = "Вообще-то ты собирался учить меня.";
"enc_c1e2o1_dialog_9a" = "Да, точно. А... это была проверка. И ты ее прошел!";

//Encounter 3
"enc_c1e3o1_dialog_1a" = "Парень! Что тут у тебя? Инфернус?";
"enc_c1e3o1_dialog_2a" = "Его зовут Берпи. Он — чудо.";
"enc_c1e3o1_dialog_3a" = "Слаги Инфернус превращаются в мощных огненных созданий.";
"enc_c1e3o1_dialog_4a" = "Берпи говорит, что он не прочь потренироваться в превращении.";
"enc_c1e3o1_dialog_5a" = "Подбери несколько плиток с огнем, чтобы придать Берпи силы для атаки.";
"enc_c1e3o1_dialog_6a" = "Продолжай! Ему нужно больше энергии.";
"enc_c1e3o1_dialog_7a" = "Подбери пять плиток за один раз, чтобы зарядить Берпи на один уровень.";
"enc_c1e3o1_dialog_8a" = "Теперь Берпи полон энергии. Коснись слага, чтобы раскрыть его новую силу!";
"enc_c1e3o1_dialog_9a" = "Ой-ой-ой. Похоже, ты уже освоился. Поединок!";
"enc_c1e3o1_dialog_10a" = "Ох! В следующий раз постарайся не поджечь мои штаны.";
"enc_c1e3o1_dialog_10b" = "Я думаю, ты готов к своему первому настоящему поединку. ПРОНТО!!!";

//Encounter 4
"enc_c1e4o1_dialog_1a" = "Великий и могучий Пронто не поддастся, чтобы дать тебе потренироваться. Приготовься к полному поражению!";
"enc_c1e4o1_dialog_2a" = "Да...";
"enc_c1e4o1_dialog_3a" = "Для меня большая честь служить такому талантливому слагслингеру. Пронто одолжит тебе своего любимого слага, Вонючку!";
"enc_c1e4o1_dialog_4a" = "Фу... то есть спасибо, Пронто!";

/* End Chapter 1 */


