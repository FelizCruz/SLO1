/* Chapter 1 */

//Encounter 1
"enc_c1e1o1_dialog_1a" = "太棒了！ 穴巨人！ 我一直想遇到穴巨人！ ";
"enc_c1e1o1_dialog_2a" = "我是柯德·赞恩。 你不是本地人吧？ ";
"enc_c1e1o1_dialog_2b" = "我得教教你如何防身。 看下面的方块格子。 ";
"enc_c1e1o1_dialog_3a" = "点按并移动方块然后将其拖至相 邻方块上。";
"enc_c1e1o1_dialog_4a" = "干掉不错， 小家伙！ 这就够了。 ";
"enc_c1e1o1_dialog_5a" = "好的， 伊莱， 现在我来演示一下如何匹配方块。 ";
"enc_c1e1o1_dialog_6a" = "现在来看看你能否匹配三个发射器方块。 ";
"enc_c1e1o1_dialog_7a" = "哦！ 这是你第一次发射器射击吗？ ！ 你绝不可能战胜我啊。 ";
"enc_c1e1o1_dialog_7b" = "我敢打赌， 你肯定没法再来一次。 ";
"enc_c1e1o1_dialog_8a" = "移动发射器方块， 进行另一次匹配！ ";
"enc_c1e1o1_dialog_9a" = "哇！ 好吧， 你肯定特别擅长射击...但是我也有发射器！ 咱们来决斗吧！ ";
"enc_c1e1o1_dialog_10a" = "哦！ 哇！ 你这么做是什么意思？ 我告诉过你应该...";

//Encounter 2
"enc_c1e2o1_dialog_1a" = "干得漂亮！ 下一步： 治疗。 ";
"enc_c1e2o1_dialog_2a" = "匹配三个绿色方块， 即可恢复健康条。 ";
"enc_c1e2o1_dialog_3a" = "感觉好点了吗？ 很好！ ";
"enc_c1e2o1_dialog_4a" = "抱歉， 我的发射器有点小麻烦。 你最好再治疗一次。 ";
"enc_c1e2o1_dialog_5a" = "来试试匹配这四个健康方块。 ";
"enc_c1e2o1_dialog_6a" = "一次操作中匹配方块越多越好。 ";
"enc_c1e2o1_dialog_6b" = "现在， 来看看你能在决斗中撑多久。 ";
"enc_c1e2o1_dialog_7a" = "糟糕， 我差点就赢了。 ";
"enc_c1e2o1_dialog_8a" = "你不是要教教我吗？ ";
"enc_c1e2o1_dialog_9a" = "额， 好吧。 不过...这只是个测试...你通过了！ ";

//Encounter 3
"enc_c1e3o1_dialog_1a" = "决斗！ 你有一个伊佛纳斯精灵？ ";
"enc_c1e3o1_dialog_2a" = "他的名字叫波比。 他很棒的！ ";
"enc_c1e3o1_dialog_3a" = "伊佛纳斯精灵可变形成为一个强大的火 焰生物。 ";
"enc_c1e3o1_dialog_4a" = "波比说他想练习变形。 ";
"enc_c1e3o1_dialog_5a" = "尝试匹配一些火焰方块， 来增加波比的攻击力吧！ ";
"enc_c1e3o1_dialog_6a" = "继续努力！ 他需要更多果汁。 ";
"enc_c1e3o1_dialog_7a" = "一次匹配五个方块， 可将波比充能一个级别。 ";
"enc_c1e3o1_dialog_8a" = "现在波比已经充满能量， 点按精灵， 发起新的攻击！ ";
"enc_c1e3o1_dialog_9a" = "哇 哇 哇 哇。 好的， 我想你已经找到了窍门， 决斗吧！ ";
"enc_c1e3o1_dialog_10a" = "哟！ 下次可别再把我的裤子点着了！ ";
"enc_c1e3o1_dialog_10b" = "我想， 你已经准备好进行第一次真正的决斗了！ 布朗多！ ！ ！ ！ ！ ！ ";

/* End Chapter 1 */

