//Encounter 7
"enc_c4e7o1_dialog_1a" = "¿Os sabéis todos el plan? Ni siquiera la Banda de Shane será capaz de cogernos tras estos muros de hielo!";
"enc_c4e7o1_dialog_2a" = "¿Ese es tu plan maestro? ¿Esconderte tras un poco de agua congelada?";
"enc_c4e7o1_dialog_3a" = "Está aquí! ATACAR!";
"enc_c4e7o1_dialog_4a" = "Hotel Uniform India Delta Alfa!";
"enc_c4e7o1_dialog_4b" = "Que significa HUIDA!!!";

//Encounter 8
"enc_c4e8o1_dialog_1a" = "¿Qué está haciendo el Clan Sombra aquí?";
"enc_c4e8o1_dialog_2a" = "Grrrrrr!";
"enc_c4e8o1_dialog_3a" = "Ok. Menos preguntas y más pelea!";
"enc_c4e8o1_dialog_4a" = "Esperemos que eso les mantenga lejos. Debemos deshacernos de este pedido antes de llamar más la atención.";

//Encounter 9
"enc_c4e9o1_dialog_1a" = "Llámamé Señor Sábado...";
"enc_c4e9o1_dialog_2a" = "Prefiero llamarte Marioneta de Blakk.";
"enc_c4e9o1_dialog_3a" = "El Señor Sábado no es ninguna marioneta! Cómete esta!";
"enc_c4e9o1_dialog_4a" = "El Señor Sábado volverá... con refuerzos.";
"enc_c4e9o1_dialog_5a" = "No te preocupes Eructín! Ya casi estamos!";

//Encounter 10
"enc_c4e10o1_dialog_1a" = "¿Qué crees que vas a ganar irrumpiendo aquí?";
"enc_c4e10o1_dialog_2a" = "Eres un monstruo. No volverás a corromper slugs NUNCA MÁS.";
"enc_c4e10o1_dialog_3a" = "Tienes razón. Soy un monstruo, pero tú eres sólo un chaval. ¿Quien crees que ganará este duelo?";
"enc_c4e10o1_dialog_4a" = "Se acabaron tus demonios, Nacho.";
"enc_c4e10o1_dialog_5a" = "Esta es sólo una de las decenas de Estaciones de Demonización que tenemos. ";
"enc_c4e10o1_dialog_5b" = "La refinería de Agua Oscura convertirá a todos tus queridos slugs en diablos! Has perdido, Shane.";
"enc_c4e10o1_dialog_6a" = "¿Cómo?! No...";

//Encounter 11

/* End Chapter 4 */



/* Chapter 5 */


//Encounter 1
"enc_c5e1o1_dialog_1a" = "Dr. Blakk ha conseguido que mis slugs se volvieran más fuertes. Está vez te derrotaré!";
"enc_c5e1o1_dialog_2a" = "¿Has dejado que Dr. Blakk corrompiera tus slugs? Puedo sanarlas. Deja que te ayude.";
"enc_c5e1o1_dialog_3a" = "Ni de coña! Duelo!";
"enc_c5e1o1_dialog_4a" = "Bien! Ahora tus slugs están sanadas.";

//Encounter 2
"enc_c5e2o1_dialog_1a" = "Oh no. Sedo! Tú también trabajas para Blakk?";
"enc_c5e2o1_dialog_2a" = "El increíble Sedo trabaja para el mejor pagador. ¿Tienes una contraoferta?";
"enc_c5e2o1_dialog_3a" = "...";
"enc_c5e2o1_dialog_4a" = "Sedo lo suponía…";

//Encounter 3
"enc_c5e3o1_dialog_1a" = "Me has vacilado dos veces. No dejaré que lo vuelvas a hacer.";
"enc_c5e3o1_dialog_2a" = "Peleas en el bando equivocado John Bull. Si aún no te has dado cuenta, me temo que nunca lo harás.";
"enc_c5e3o1_dialog_3a" = "Estoy en el bando ganador, Shane, y tengo la slug que lo demostrará.";
"enc_c5e3o1_dialog_4a" = "Largo de aquí, John. No volverás a ayudar a Blakk a demonizar slugs nunca más.";

//Encounter 4
"enc_c5e4o1_dialog_1a" = "Tontobot 2.0 ha llegado! Tontobot 2.0 es literalmente el doble de Tontobot de lo que era Tontobot 1.0.";
"enc_c5e4o1_dialog_2a" = "Estás seguro de querer esto Tontobot?";
"enc_c5e4o1_dialog_3a" = "Tontobot no puedo evitarlo. Tontobot está programado así.";
"enc_c5e4o1_dialog_4a" = "Eli Shane tiene razón. A Tontobot 2.0 le gustaría cesar con esta vida de violencia.";
"enc_c5e4o1_dialog_4b" = "Tontobot 2.0 se convertirá en pintor y beneficiará a la sociedad con su arte.";

//Encounter 5
"enc_c5e5o1_dialog_1a" = "Pensé que habías dicho no ser la marioneta de Blakk.";
"enc_c5e5o1_dialog_2a" = "Blakk ha duplicado mi paga. El Señor Sábado sabe reconocer una buena oferta cuando se le ofrece.";
"enc_c5e5o1_dialog_3a" = "Me has vencido, Shane, pero escúchame bien. Volveré a por ti.";

//Encounter 6
"enc_c5e6o1_dialog_1a" = "Shorty! Glasses! Billy! Por favor parar ya. Demonizar slugs es un enorme error. Slugterra no podrá soportarlo.";
"enc_c5e6o1_dialog_2a" = "Estás celoso de que nuestras slugs sean tan poderosas. Voy a demostrarte lo que es ser un verdadero Tirador.";

"enc_c5e6o2_dialog_1a" = "No te preocupes Shorty, mi Diablo de Hielo no puede perder. Derrotaré a Eli.";
"enc_c5e6o2_dialog_2a" = "¿Es que no lo entiendes? Estáis ayudando a Blakk a destruirlo todo. Tenéis que parar.";
"enc_c5e6o2_dialog_3a" = "Oof. Billy, ayúdanos!";

"enc_c5e6o3_dialog_1a" = "Billy, por favor... escúchame un momento…estás cometiendo un gran error.";
"enc_c5e6o3_dialog_2a" = "Demasiado tarde, Eli. Ya hemos tomado nuestra decisión.";
"enc_c5e6o3_dialog_3a" = "Nunca es demasiado tarde. ¿Dónde está Blakk?";

//Encounter 7
"enc_c5e7o1_dialog_1a" = "Mmmm Zampa! Masca!";
"enc_c5e7o1_dialog_2a" = "Me imagino que no hay forma de convencerte para que no me ataques.";
"enc_c5e7o1_dialog_3a" = "Lo único que me gusta más que llenar mi barriga es vencerte.";
"enc_c5e7o1_dialog_4a" = "Tengo que encontrar a Blakk y terminar con esto.";

//Encounter 8
"enc_c5e8o1_dialog_1a" = "Así que la Banda de Shane ha caído en nuestra trampa!";
"enc_c5e8o1_dialog_1b" = "Cuando termine contigo voy a llevar tus slugs a Blakk para que las demonice!";
"enc_c5e8o1_dialog_2a" = "Jamás permitiré que pongas tus sucias manos cerca de mis slugs.";
"enc_c5e8o1_dialog_3a" = "Lode! Prepárate. Voy a acabar con este chaval.";

"enc_c5e8o2_dialog_1a" = "Lode! No tienes que hacer lo que te dice Locke. Deja que cure a tus slugs.";
"enc_c5e8o2_dialog_2a" = "Puede que Locke haya perdido pero yo voy a destrozarte! Boom!";
"enc_c5e8o2_dialog_3a" = "Corre! Corre!";

//Encounter 9
"enc_c5e9o1_dialog_1a" = "Cuando tu padre te hablaba de monstruos que te sacudían en medio de la noche, él estaba hablando de mí, Shane.";
"enc_c5e9o1_dialog_1b" = "Soy lo que te han enseñado a temer. Soy la oscuridad. Soy la desesperación.";
"enc_c5e9o1_dialog_1c" = "Soy diablos, fantasmas y demonios. Soy tu peor pesadilla, Eli Shane.";
"enc_c5e9o1_dialog_2a" = "Mi padre me contó otra historia.";
"enc_c5e9o1_dialog_2b" = "Una en la que los monstruos siempre perdían porque el miedo no les hacía más poderosos... Pero yo no te tengo miedo.";
"enc_c5e9o1_dialog_3a" = "Te he vencido Nacho. Ahora dime dónde está Blakk.";

//Encounter 10
"enc_c5e10o1_dialog_1a" = "Puedes luchar cuanto quieras, pero yo gobernaré sobre TODO Slugterra.";
"enc_c5e10o1_dialog_1b" = "He creado un nuevo orden mundial, y tú, Eli Shane serás aplastado por la maquinaria del progreso.";
"enc_c5e10o1_dialog_2a" = "Serás el gobernante de nada. Sin las slugs, Slugterra moriría.";
"enc_c5e10o1_dialog_3a" = "AAARRRGGGG!";

"enc_c5e10o2_dialog_1a" = "NO... ME... DETENDRÁS!!!";
"enc_c5e10o2_dialog_2a" = "Se acabó, Eructín! Lo conseguimos! Paramos a Blakk!";

/* End Chapter 5 */



/* Chapter 6 */


//Encounter 1
"enc_c6e1o1_dialog_1a" = "Buenas tardes, Maestro Shane.";
"enc_c6e1o1_dialog_2a" = "¿Quién eres? ¿Por qué me estás siguiendo?";
"enc_c6e1o1_dialog_3a" = "Debes de creer que has escapado, pero la jungla guarda muchas sorpresas.";

//Encounter 2

//Encounter 3
"enc_c6e3o1_dialog_1a" = "Lista de cómo escapar de prisión. Paso uno: conseguir munición. Hecho! Paso dos: salir de la celda. Hecho!";
"enc_c6e3o1_dialog_2a" = "Graaarrraaa!";
"enc_c6e3o1_dialog_3a" = "Paso tres: que no me zombifiquen!";
"enc_c6e3o1_dialog_4a" = "Urrrrrrgggg!";
"enc_c6e3o1_dialog_5a" = "Ah. Puede que los zombies sean terroríficos, pero tienen malísima puntería.";

//Encounter 4
"enc_c6e4o1_dialog_1a" = "Prisionero #371. Por favor regrese a su celda. Si no obedece será duramente amonestado.";
"enc_c6e4o1_dialog_2a" = "Asumiré el riesgo. Voy a enseñarle a esta máquina como es un verdadero Tirador.";

//Encounter 5
"enc_c6e5o1_dialog_1a" = "Arrrrg!";
"enc_c6e5o1_dialog_2a" = "No, muchas gracias. La sopa de sesos no me sienta del todo bien.";
"enc_c6e5o1_dialog_3a" = "...Uuuurrrg.";
"enc_c6e5o1_dialog_4a" = "Esto no pinta bien. Será mejor llegar hasta el fondo del asunto antes de que alguien salga herido.";

//Encounter 6
"enc_c6e6o1_dialog_1a" = "Ey! Tú no eres un zombi!";
"enc_c6e6o1_dialog_2a" = "Y esa es la razón por la que te voy a quitar esas slugs y ese arma.";

//Encounter 7
"enc_c6e7o1_dialog_1a" = "He estado aquí encerrado durante 23 años gracias a Will Shane. Me quitó mis slugs, mi arma y mi meca.";
"enc_c6e7o1_dialog_1b" = "Ahora es mi turno, Shane. Esta será mi venganza.";

//Encounter 8
"enc_c6e8o1_dialog_1a" ="Parecéis enfadados chicos. Quizás necesitéis unas vacaciones.";
"enc_c6e8o1_dialog_2a" = "El Sr. Sábado nos contrató para hacer una limpieza por aquí. Es hora de tirar la basura.";
"enc_c6e8o1_dialog_3a" = "Esto apesta. Voy a tomarme la semana libre.";

"enc_c6e8o2_dialog_1a" = "Necesitamos más días de baja por enfermedad.";

"enc_c6e8o3_dialog_1a" = "Puede que seas bueno, Eli Shane, pero no vas a ganar este duelo.";
"enc_c6e8o3_dialog_2a" = "Ya basta! Vamos a hacer huelga!";

//Encounter 9
"enc_c6e9o1_dialog_1a" = "Idiota! Te aplastaré como una cucaracha!";

//Encounter 10
"enc_c6e10o1_dialog_1a" = "Estás demostrando ser un problema más grande de lo que pensábamos. Pero puedes seguir siendo útil, Shane.";
"enc_c6e10o1_dialog_1b" = "¿Una última palabra antes de unirte a mi ejército de zombis?";
"enc_c6e10o1_dialog_2a" = "No eres mejor que Blakk y sus diablos. Tus días de controlar mentes han terminado, Sábado.";
"enc_c6e10o1_dialog_3a" = "Devuélveme a Eructín!";

/* End Chapter 6 */

/* Chapter 7 */


//Encounter 1
"enc_c7e1o1_dialog_1a" = "Banda de Shane! Parar vuestras mecas ahora mismo!";
"enc_c7e1o1_dialog_1b" = "Debo devolveros a prisión o Blakk me quitará mis privilegios en la cafetería.";
"enc_c7e1o1_dialog_2a" = "Dile a tu amo que no hay celda que retenga a la Banda de Shane.";

//Encounter 2
"enc_c7e2o1_dialog_1a" = "Vaya! Bonito disfraz. ¿Quién se supone que eres?";
"enc_c7e2o1_dialog_2a" = "No es un disfraz. Soy un caballero de la fortuna";
"enc_c7e2o1_dialog_2b" = "…un espadachín, un bucanero. Practico el dulce intercambio comercial.";
"enc_c7e2o1_dialog_3a" = "Oh, eso me parece una vida de pirata!";

//Encounter 3
"enc_c7e3o1_dialog_1a" = "Oye. Puedo ver mi casa desde aquí!";
"enc_c7e3o1_dialog_2a" = "¿Estás saqueando la ciudad en la que vives?";
"enc_c7e3o1_dialog_3a" = "Aquí es donde dice el mapa que debemos ir, y eso haremos. De otro modo no seríamos piratas.";
"enc_c7e3o1_dialog_4a" = "Creo que mejor me voy a casa.";

//Encounter 4
"enc_c7e4o1_dialog_1a" = "He entrenado setenta y cinco formas diferentes de combate. Ni de coña pasas por aquí!";

//Encounter 5
"enc_c7e5o1_dialog_1a" = "¿Qué hacen ustedes tiradores en mi barco?";
"enc_c7e5o1_dialog_1b" = "Alto! Están intentando desencadenar un motín!";
"enc_c7e5o1_dialog_2a" = "Nunca me cogerán vivo! Me hundiré con mi  barco!";

//Encounter 6
"enc_c7e6o1_dialog_1a" = "Encontramos el mapa del tesoro limpiamente. Ahora fuera de nuestro camino!";
"enc_c7e6o1_dialog_2a" = "Me pregunto por qué hay tantas copias de éste mapa flotando por ahí.";

//Encounter 7
"enc_c7e7o1_dialog_1a" = "Eso si que es un gran cañón. ¿Por qué en lugar de dispararnos, no te largas?";
"enc_c7e7o1_dialog_2a" = "Boom!" ;
"enc_c7e7o1_dialog_3a" = "Creo que eso responde a tu pregunta!";

//Encounter 8

//Encounter 9
"enc_c7e9o1_dialog_1a" = "Gator tiene el mapa secreto. Gator debe conseguir el tesoro el primero para que Gator pueda retirarse de la vida de pirata.";
"enc_c7e9o1_dialog_1b" = "Gator será ganador!";
"enc_c7e9o1_dialog_2a" = "Tarde Gator";

//Encounter 10
"enc_c7e10o1_dialog_1a" = "Whoa, eres una gran tipo.";
"enc_c7e10o1_dialog_2a" = "Grunt.";
"enc_c7e10o1_dialog_3a" = "Grunt.";

"enc_c7e10o2_dialog_1a" = "El Capitán está ocupado ahora mismo pirateando. ¿Podrías volver más tarde?";

"enc_c7e10o3_dialog_1a" = "Has destrozado mi barco, dispersado a mi tripulación, pirateado mi tesoro pirata y ahora ¿te vas a enfrentar a mí?" ;
"enc_c7e10o3_dialog_1b" = "Tienes valor. Pero se necesita más que eso para abatir a un maestro pirata.";
"enc_c7e10o3_dialog_2a" = "No! Mi Tesoro!" ;

/* End Chapter 7 */

/* Chapter 8 */


//Encounter 1
"enc_c8e1o1_dialog_1a" = "Shane! Tras mi última humillación el Dr.Blakk me quitó mis demonios.";
"enc_c8e1o1_dialog_1b" = "No dejaré que vuelvas a vencerme.";

//Encounter 2
"enc_c8e2o1_dialog_1a" = "Hay muchos bandidos por esta zona.";
"enc_c8e2o1_dialog_1b" = "Quizás alguno sepa que es lo que sucede en el Reino Topoide.";
"enc_c8e2o1_dialog_2a" = "Ahh, otra vez no!";

//Encounter 3
"enc_c8e3o1_dialog_1a" = "Acabemos con esto. Tenemos trabajo que hacer. Y no te vas a interponer en nuestro camino esta vez, Shane.";
"enc_c8e3o2_dialog_1a" = "No! Va explotar todo!";

//Encounter 4
"enc_c8e4o1_dialog_1a" = "La Banda de Shane está aquí! Activar la alarma! Hacer saltar las trampas!";
"enc_c8e4o1_dialog_2a" = "Vale... Así que el pasar desapercibidos no ha funcionado. De todos modos conseguimos entrar. Acabemos con esto!";
"enc_c8e4o2_dialog_1a" = "Aunque me ganes, un centenar más de tiradores me reemplazarán.";
"enc_c8e4o2_dialog_2a" = "Oh Espera. Todos han huido.";

//Encounter 5
"enc_c8e5o1_dialog_1a" = "Jeen es capaz de partir ladrillos por la mitad con su bigote.";

//Encounter 6
"enc_c8e6o1_dialog_1a" = "Jeen es un verdadero pusilánime. Creo que pronto te darás cuenta que yo no lo soy.";
"enc_c8e6o1_dialog_2a" = "Aun no has visto nada.  El líder de la Banda del Dolor te va a mostrar lo que es el verdadero poder!";

//Encounter 7
"enc_c8e7o1_dialog_1a" = "Ey, te pareces a mí...";
"enc_c8e7o1_dialog_1b" = "Pero menos guapo!";

//Encounter 8

//Encounter 9
"enc_c8e9o1_dialog_1a" = "El formidable Sedo se ha convertido en el Rey de los Topoides.";
"enc_c8e9o1_dialog_1b" = "Suelta esa corona impostor!";

//Encounter 10
"enc_c8e10o1_dialog_1a" = "El Sensacional Sedo no será vencido por alguien como tú. Sedo vencerá!";
"enc_c8e10o1_dialog_2a" = "Nooooo! Mi Meca-Topoide! La has roto!";

/* End Chapter 8 */

/* Chapter 9 */


//Encounter 1 - The Trips
"enc_c9e1o1_dialog_1a" = "Tres veces el poder del fuego significa que tienes tres veces la oportunidad de ser escogido.";
"enc_c9e1o2_dialog_1a" = "No. No nos iremos.";
"enc_c9e1o3_dialog_1a" = "Soy el más válido de mis hermanos. La Maestra Imbatible me escogerá a mí, seguro!";

//Encounter 2

//Encounter 3 - Sid the Kid
"enc_c9e3o1_dialog_1a" = "Cuando la Maestra me vea vencerte, se dará cuenta que soy su siguiente pupilo.";
"enc_c9e3o1_dialog_2a" = "Ni de coña!";

//Encounter 4 - King of Sling
"enc_c9e4o1_dialog_1a" = "Una vez desvele los secretos de la Maestra Imbatible, mi reino será mejor dirigido que nunca que nunca!";
"enc_c9e4o1_dialog_2a" = "Eso no importa. Un verdadero rey sirve, no manda.";

//Encounter 5 - Trixie
"enc_c9e5o1_dialog_1a" = "Ey Trixie! Gracias por venir a apoyarme.";
"enc_c9e5o1_dialog_2a" = "¿Apoyarte? He venido a competir.  Creías que todo esto era sólo por tí?";

//Encounter 6 - Fake Duelist
"enc_c9e6o1_dialog_1a" = "Tan sólo un rival entre la Maestra y mi entrenamiento con ella.";
"enc_c9e6o1_dialog_1b" = "El único problema es que no se quién es este tipo.";

//Encounter 7 - Unbeatable Master
"enc_c9e7o1_dialog_1a" = "Muy bien, bloquea las rodillas, veamos que puedes dar. Esto no es un duelo, es una evaluación.";
"enc_c9e7o1_dialog_1b" = "La decisión será sólo mía.";

//Encounter 8 - Young Dr. Blakk
"enc_c9e8o1_dialog_1a" = "Pasé toda la noche calibrando mi arma .Tu derrota es inevitable.";
"enc_c9e8o1_dialog_2a" = "El arma no hace al tirador, Tadeus!";
"enc_c9e8o1_dialog_2b" = "Vas a perder!";

//Encounter 9 - Twist
"enc_c9e9o1_dialog_1a" = "No vas a ganar, Twist!";
"enc_c9e9o1_dialog_2a" = "Nunca se sabe, Eli.";
"enc_c9e9o1_dialog_3a" = "Estás respaldando al tipo equivocado, Twist... Y lo sabes.";

//Encounter 10 - Dr. Blakk
"enc_c9e10o1_dialog_1a" = "No.";
"enc_c9e10o1_dialog_2a" = "Perdóname.";
"enc_c9e10o1_dialog_3a" = "He dicho no. Se acabó. No volverás a dañar a otra persona inocente y marcharte como si nada.";

/* End Chapter 9 */

/* Chapter 10 */


//Encounter 1 - Broken Auto-Cannon
"enc_c10e1o1_dialog_1a" = "EL nuevo Alcaide me envío al Montón Chatarra por tu culpa, Prisionero #371.";
"enc_c10e1o1_dialog_1b" = "Tendré mi ven-bzzzzzzt-ganza.";

//Encounter 2 - Doombot 1.0 & Doombot 2.0
"enc_c10e2o1_dialog_1a" = "Tontobot 1.0? Que estás haciendo aquí?";
"enc_c10e2o1_dialog_2a" = "Después de que el programa Tontobot fuera interrumpido, todos los Tontobots fuimos enviados aquí.";
"enc_c10e2o1_dialog_2b" = "Tontobot 1.0 iniciando programa de batalla!";
"enc_c10e2o2_dialog_1a" = "Tontobot 2.0 desmontar? No desmontar!";
"enc_c10e2o2_dialog_1b" = "Tontobot 2.0 iniciando programa de batalla!";

//Encounter 3 - Mecha-Mole
"enc_c10e3o1_dialog_1a" = "RAAA-bzzzzzzzzt-AAAAAWR";
"enc_c10e3o1_dialog_1b" = "Ese ruido ya lo he oído antes...";

//Encounter 4 - Tough Guy Gang Member #1 -
"enc_c10e4o1_dialog_1a" = "Esta área está restringida si no tiene permiso del Jefe Ember.";
"enc_c10e4o1_dialog_1b" = "Abandona el Almacén Profundo y deja aquí tus slugs y tu arma.";
"enc_c10e4o1_dialog_2a" = "Eso no va a pasar.";

//Encounter 5 - Tough Guy Gang Member #2 - Welder
"enc_c10e5o1_dialog_1a" = "¿Quién sois?";
"enc_c10e5o1_dialog_2a" = "La Banda de Shane. Quizás hayas oído hablar de nosotros.";
"enc_c10e5o1_dialog_3a" = "Si, y quizás tu hayas oído hablar de nosotros. Somos Los Tíos Duros.";

//Encounter 6 - Tough Guy Gang Member #3 - Neckbrace
"enc_c10e6o1_dialog_1a" = "Algunas cosas de aquí pueden ser gratis, pero el llevártelas no lo es.";
"enc_c10e6o1_dialog_1b" = "Le debes una buena al Jefe Ember por esto.";

//Encounter 7 - Tough Guy Gang Member #4 - Troll
"enc_c10e7o1_dialog_1a" = "Venga, colegas. Ese cristal vale menos que vosotros. Dejar que nos lo llevemos y nos iremos de aquí.";
"enc_c10e7o1_dialog_2a" = "Bien, que sea el Jefe Ember quien decida eso.";

//Encounter 8 - Boss Ember
"enc_c10e8o1_dialog_1a" = "Soy el guardián del Alamacén Profundo. Ningún objeto o cliente deja este lugar sin mi permiso.";
"enc_c10e8o1_dialog_1b" = "Este es el trato, Shane. Tú y yo. Uno a uno. Si ganas, te llevas el Cristal Vitalis. Si pierdes, me quedo con tu arma.";

//Encounter 9

//Encounter 10 - Angry Boss Ember
"enc_c10e10o1_dialog_1a" = "Eres un tramposo, Ember. ¡He ganado con todas las de la ley! ¡Dame el cristal Vitalis!";
"enc_c10e10o1_dialog_2a" = "Metí. No vas a ir a ninguna parte, Shane. Este es MI desguace.";

/* End Chapter 10 */

/* Chapter 11 */

//Encounter 1 - Glasses
"enc_c11e1o1_dialog_1a" = "¡Manos arriba! ¡Los Hooligang estamos hambrientos, sedientos y deseosos de ponernos ciegos de vasos de leche y cacahuetes!";

//Encounter 2 - Shorty
"enc_c11e2o1_dialog_1a" = "¡Aquí donde me ves, he sido cocinero antes que villano! ¡Os voy a limpiar, pelar, triturar y servir con una manzana en la boca!";

//Encounter 3 - Billy
"enc_c11e3o1_dialog_1a" = "¿Otra vez tú?";
"enc_c11e3o1_dialog_1b" = "¡Fuera de mi vista, Eli! ¡Tengo un hambre que me muero, y llevo tres días comiendo pienso para slugs!";
"enc_c11e3o1_dialog_2a" = "¿Por qué has...? No, bien pensado, déjalo. Mejor no pregunto.";

//Encounter 4 - Jeen
"enc_c11e4o1_dialog_1a" = "¿Qué estáis haciendo aquí? ¿Es que estáis conchabados con los Hooligang?";
"enc_c11e4o1_dialog_1b" = "¡La Banda del Dolor clama venganza! ¡Jeen va a aplastar a Eli Shane con el poder de sus patillas!";
"enc_c11e4o1_dialog_1c" = "¿Seguro que no habéis venido con los Hooligang? Lo digo por que acaban de pasar por aquí...";

//Encounter 5 - Trapsie
"enc_c11e5o1_dialog_1a" = "¡Tal vez hayas podido con las patillas de Jeen, pero no podrás conmigo!";

//Encounter 6 - Alias
"enc_c11e6o1_dialog_1a" = "Vaya, vaya, pero si es mi hermano gemelo menos agraciado... ¡Sedo es historia! ¡Ahora yo estoy al mando de la Banda del Dolor, y ardo en deseos de vengarme!";

//Encounter 7 - Welder Walter & Lil Stevie
"enc_c11e7o1_dialog_1a" = "¿Los Tíos Duros? ¿Cómo es que ya no trabajáis para el Jefe Ember?";
"enc_c11e7o1_dialog_1b" = "Nos han despedido por no ser lo bastante duros... ¡Ahora andamos buscando bronca y, de paso, otro trabajo!";
"enc_c11e7o1_dialog_2a" = "Oye, Eli... ¿No tendréis un hueco en vuestra banda, por casualidad? Mirad, este es mi curriculum.";

//Encounter 8 - Mongo
"enc_c11e8o1_dialog_1a" = "¡Ahora me dedico al voluntariado! ¡Gratis!";
"enc_c11e8o1_dialog_2a" = "¡Me presento voluntario para batirme en duelo con Eli! ¡Ahora mismo!";

//Encounter 9 - Straggus
"enc_c11e9o1_dialog_1a" = "No puedo permitirme ni comprar nuevas bombillas para mi casco de supervillano... ¡Estoy que trino!";

//Encounter 10 - Billy, Alias & Straggus
"enc_c11e10o1_dialog_1a" = "Los Hooligang, la Banda del Dolor y los Tíos Duros? ¿Qué hacéis aquí?";
"enc_c11e10o1_dialog_1b" = "¡Unos estamos hambrientos, otros queremos vengarnos y lucir palmito y otros buscamos trabajo! ¡Cuando unimos fuerzas, nada puede detenernos!";
"enc_c11e10o2_dialog_2a" = "¡Gracias a mi sed de venganza, he hecho nuevos amigos tan malvados como yo!";
"enc_c11e10o3_dialog_3a" = "¡He descubierto que es más fácil hacer realidad mis maléficos objetivos con la ayuda de unos buenos amigos!";
"enc_c11e10o3_dialog_4a" = "¡Largaos con la música a otra parte, tíos!";
"enc_c11e10o3_dialog_5a" = "No me puedo creer que hayamos perdido pese al poder de la amistad entre villanos...";

/* End Chapter 11 */

/* Chapter 12 */


//Encounter 1 - Blakk Soldier & John Bull
"enc_c12e1o1_dialog_1a" = "¡Alto ahí, rufián! ¡Quedas arrestado en nombre del doctor Thadeus Blakk!";
"enc_c12e1o1_dialog_2a" = "¿Arrestado? ¿De qué se me acusa?";
"enc_c12e1o1_dialog_1b" = "¡De practicar el tiro sin autorización!";
"enc_c12e1o1_dialog_3a" = "¡No tienes escapatoria, Shane! ¡Tienes un abismo enorme detrás!";

//Encounter 2 - Nacho
"enc_c12e2o1_dialog_1a" = "¡Danos tu arma y no seremos piadosos contigo!";
"enc_c12e2o1_dialog_2a" = "Gracias por la oferta, pero no.";
"enc_c12e2o1_dialog_3a" = "¡No mires atrás, Eli! ¡Hay una buena caída!";
"enc_c12e2o2_dialog_4a" = "¿Te dan miedo las alturas, Nacho? ¡Lo digo porque a mí no!";

//Encounter 3 - Darkbane Soldier 1
"enc_c12e3o1_dialog_1a" = "¡Caray! ¿Qué sé supone que eres?";
"enc_c12e3o1_dialog_1b" = "¡¡¡WAAARGH!!!";
"enc_c12e3o1_dialog_2a" = "¡Cuidado con las bolas de fuego!";

//Encounter 4 - Darkbane Soldier 2
"enc_c12e4o1_dialog_1a" = "¡Otro más! ¿De dónde salen esos tipos?";

//Encounter 5 - Darkbane Soldier 3
"enc_c12e5o1_dialog_1a" = "¡Waaargh!";
"enc_c12e5o1_dialog_2b" = "¡Vamos, Eructín! Tenemos que llegar al fondo de este asunto.";

//Encounter 6 - Shadow Clan Protector
"enc_c12e6o1_dialog_1a" = "¡Alto! ¡Esto es un lugar sagrado! ¡No podéis pasar!";
"enc_c12e6o1_dialog_2a" = "¡Espera! ¡Pero si soy Eli Shane!";
"enc_c12e6o1_dialog_3a" = "¡El portal slug se está debilitando! ¡Si de verdad eres Shane, debes proteger el portal y acabar con los Darkbane!";
"enc_c12e6o1_dialog_4a" = "No sé ni quiénes son esos tales Darkbane, pero vale. ¡Te ayudaré!";
"enc_c12e6o1_dialog_3b" = "Las Cavernas Profundas están llenas de una energía oscura que lo corrompe todo... ¡No bajes la guardia, joven Shane!";

//Encounter 7 - Prison Door
"enc_c12e7o1_dialog_1a" = "Muy bien, Eructín... Espero que sepas lo que haces. ¡Echa la puerta abajo!";

//Encounter 8 - Prison Guards
"enc_c12e8o1_dialog_1a" = "¡El prisionero se escapa! ¡Dad la alarma!";
"enc_c12e8o1_dialog_2a" = "¡Tus demonios no te salvarán, escoria humana!";
"enc_c12e8o1_dialog_3a" = "¡Vamos, Eructín! ¡Tenemos que largarnos de aquí a toda velocidad!";

//Encounter 9 - Prison Warden
"enc_c12e9o1_dialog_1a" = "¡He escrito un poema! Se titula «Escoria humana, regresa a tu celda». ¿Quieres oírlo?";
"enc_c12e9o1_dialog_2a" = "Esto... Vale.";
"enc_c12e9o1_dialog_1b" = "«El fuego es rojo, las rocas negras. Escoria humana, regresa a tu celda.»";
"enc_c12e9o1_dialog_2b" = "Qué talento para la poesía...";

//Encounter 10 - Darkbane Nacho
"enc_c12e10o1_dialog_1a" = "Eso sí que no me lo esperaba, Shane... ¡Nunca pensé que demonizarías tus propias slugs para salvarte!";
"enc_c12e10o1_dialog_2a" = "¡No me has dejado otra opción! ¡No puedo permitir que invadas Slugterra!";
"enc_c12e10o1_dialog_3a" = "¿Acaso has olvidado dónde estás? ¡Estás en las profundidades de las Cavernas Profundas! Ya es demasiado tarde, Eli Shane...";
"enc_c12e10o1_dialog_3b" = "¡El Behemoth destruirá tu querido portal slug y los Darkbane ocuparán el lugar que les corresponde en Slugterra!";

/* End Chapter 12 */

/* Chapter 13 */


//Encounter 1 - Darkbane 1
"enc_c13e1o1_dialog_1a" = "Creo que puedo ir olvidándome de huir discretamente...";

//Encounter 2 - Darkbane 2
"enc_c13e2o1_dialog_1a" = "¡Por el honor de los Darkbane!";

//Encounter 3 - Darkbane 3
"enc_c13e3o1_dialog_1a" = "¡No tienes escapatoria!";

//Encounter 4 - Prison Warden
"enc_c13e4o1_dialog_1a" = "¡He escrito otro poema!";
"enc_c13e4o1_dialog_2a" = "¿Por qué será que no me sorprende?";
"enc_c13e4o1_dialog_1b" = "«Escoria humana, sucia e infecta; escoria vil, despreciable y abyecta; haz el favor de regresar a tu celda.»";
"enc_c13e4o1_dialog_2b" = "¡Es aún peor que el anterior!";

//Encounter 5 - Bonus Round - Brimstone's Throne

//Encounter 6 - Darkbane Elite 1 & 2
"enc_c13e6o1_dialog_1a" = "¡Hey, chicos!";
"enc_c13e6o1_dialog_2a" = "¡No podrás vencer a la élite de los Darkbane!";
"enc_c13e6o1_dialog_3a" = "¡Arrodíllate ante nosotros y te daremos una muerte rápida!";

//Encounter 7 - Darkbane Nacho
"enc_c13e7o1_dialog_1a" = "¡No tienes nada que hacer ante la magia de los Darkbane!";
"enc_c13e7o1_dialog_2a" = "¡Mis slugs y yo os daremos vuestro merecido! ¡Ellas son las verdaderas guardianas de Slugterra!";

//Encounter 8 - Angry Nacho
"enc_c13e8o1_dialog_1a" = "¡Nacho! ¿Qué es esto? ¿Eres un Darkbane?";
"enc_c13e8o1_dialog_2a" = "Ahora ya conoces mi secreto. Ni siquiera el doctor Blakk lo sabe.";
"enc_c13e8o1_dialog_1b" = "¡No voy a permitir que te vayas, Eli!";

//Encounter 9 - Behemoth
"enc_c13e9o1_dialog_1a" = "Woah! Eres un tío grande!";
"enc_c13e9o1_dialog_2a" = "¡Raaargh!";
"enc_c13e9o1_dialog_3a" = "¡Cuanto más grandes son, más dura es la caída!";

//Encounter 10 - Brimstone
"enc_c13e10o1_dialog_1a" = "¡Los Darkbane volveremos a ser los amos de Slugterra! ¡Es nuestro destino!";
"enc_c13e10o1_dialog_2a" = "¡No te dejaré pasar!";
"enc_c13e10o1_dialog_1b" = "¡Destruiré esta caverna! ¡Convertiré el portal en un cráter ardiente!";
"enc_c13e10o1_dialog_3a" = "¡NOOO! ¡No puedo fracasar ahora, después de tanto tiempo!";
"enc_c13e10o1_dialog_4a" = "¡Eructín! ¡Manda a Brimstone de vuelta a su casa!";

/* End Chapter 13 */

/* Chapter 14 */


//Encounter 1 - Pronto, Kord and Trixie
"enc_c14e1o1_dialog_1a" = "¿Listo para practicar, Pronto?";
"enc_c14e1o1_dialog_1b" = "¡Pronto siempre está preparado para luchar! ¿Sabías que Pronto es un tirador de slugs famoso entre los topoides?";
"enc_c14e1o2_dialog_2a" = "¡No te descuides, Eli! Los tiradores de slug deben hacer ejercicio para mantenerse a punto.";
"enc_c14e1o2_dialog_2b" = "¡Venga!";
"enc_c14e1o3_dialog_3a" = "¡Eli, pareces cansado! ¡Así será más fácil vencerte en un duelo!";
"enc_c14e1o3_dialog_3b" = "¿Sabes qué? Tengo un poco de sueño.";

//Encounter 2 - Dr.Blakk
"enc_c14e2o1_dialog_1a" = "¡Blakk! ¿Qué haces aquí? ¡Tú no participas en los torneos de tiro de slugs!";
"enc_c14e2o1_dialog_1b" = "¡Es la primera vez que te veo! ¡Prepárate para luchar, forastero!";

//Encounter 3 - Spirex
"enc_c14e3o1_dialog_1a" = "¡Eli Shane! ¡Estás más enredado en tus sueños que una mosca en una tela de araña!";

//Encounter 4 - Eli
"enc_c14e4o1_dialog_1a" = "¡Eres... yo! ¿Qué está ocurriendo aquí?";
"enc_c14e4o1_dialog_2a" = "¡Espera un momento! ¡Yo soy el verdadero Eli Shane!";

//Encounter 5 - Young Blakk
"enc_c14e5o1_dialog_1a" = "¡Tu cara me suena! Pareces... el Dr. Blakk de joven.";

//Encounter 6 - Behemoth
"enc_c14e6o1_dialog_1a" = "¡Vaya, qué grande eres! ¿Cómo has entrado en el torneo? ¡No tienes armas!";
"enc_c14e6o1_dialog_2a" = "¡Rrrrrraaaau!";

//Encounter 7 - Angry Blakk
"enc_c14e7o1_dialog_1a" = "¡Otra vez tú! ¿Por qué insistes en interponerte en mi camino?";
"enc_c14e7o1_dialog_2a" = "¡Siempre has tenido mal genio!";

//Encounter 8 - Unbeatable Master
"enc_c14e8o1_dialog_1a" = "¡La vida es solo una ilusión, Eli! La verdadera sabiduría se encuentra en los sueños. ¡Busca aquel que tanto anhelas!";
"enc_c14e8o1_dialog_2a" = "¡Espera! ¿Cómo sabré que he encontrado a esta persona?";
"enc_c14e8o1_dialog_2b" = "Tu corazón sabe lo que tu mente aún no conoce.";

//Encounter 9 - Gat Blakk
"enc_c14e9o1_dialog_1a" = "¡Eso no parece un arma reglamentaria!";
"enc_c14e9o1_dialog_2a" = "¡Puede que sea tu sueño, Eli Shane, pero me vengaré! ¡Prepárate para morir!";

//Encounter 10 - Will Shane
"enc_c14e10o1_dialog_1a" = "¡Eli! Te has enfrentado a muchos peligros a lo largo de tus viajes. Veamos lo que has aprendido.";
"enc_c14e10o1_dialog_2a" = "¡Papá, estás vivo! Te he buscado por todas partes...";
"enc_c14e10o1_dialog_3a" = "Estoy muy orgulloso de ti, hijo. Eres un verdadero Shane.";
"enc_c14e10o1_dialog_3b" = "¡Vuelve conmigo! Tengo tanto que preguntarte...";
"enc_c14e10o1_dialog_3c" = "¡Ahora eres un Shane, Eli! Nos volveremos a ver, cuando todo parezca derrumbarse. Adiós, hijo.";

/* End Chapter 14 */

/* Chapter 15 */


//Encounter 1 - Dr.Blakk
"enc_c15e1o1_dialog_1a" = "¡Veo que has recibido mi mensaje!";
"enc_c15e1o2_dialog_1a" = "¿Por qué me has traído aquí, Blakk?";
"enc_c15e1o1_dialog_2a" = "Es un lugar muy importante, Eli. ¿Sabes por qué? Te contaré una historia.";

//Encounter 2 - Angry Miner
"enc_c15e2o1_dialog_1a" = "¡Esta es la mina de Viggo Dare! ¡Aquí los nuevos obreros deben saber a qué atenerse!";
"enc_c15e2o2_dialog_1b" = "¡No quiero problemas!";

//Encounter 3 - Foreman
"enc_c15e3o1_dialog_1a" = "¡Déjame pasar!";
"enc_c15e3o2_dialog_1a" = "No puedes salir de aquí por las buenas. ¡Ahora perteneces a Viggo Dare!";

//Encounter 4 - The Heavy, The Rat
"enc_c15e4o1_dialog_1a" = "¡Anda, mira! ¡Es el fugitivo!";
"enc_c15e4o1_dialog_2a" = "¡Tenemos que llevarte de vuelta a la mina! Órdenes del jefe.";

//Encounter 5 - Young Will Shane
"enc_c15e5o1_dialog_1a" = "¡Alto! ¿Le has dado una paliza a dos ciudadanos?";
"enc_c15e5o2_dialog_1a" = "¿Qué? Esos son los hombres de Viggo Dare. ¡Ellos me atacaron!";
"enc_c15e5o2_dialog_1b" = "¡Soy Shane! ¡Te lo pensarás dos veces antes de dar problemas en esta caverna!";

//Encounter 6 - Viggo, Dare, The Rat
"enc_c15e6o1_dialog_1a" = "¡Otra vez tú! El jefe se va a poner de mal humor...";
"enc_c15e6o1_dialog_1b" = "¡Me has causado muchos problemas! Vuelve a la mina antes de que sea yo el que te arrastre hacia allí.";
"enc_c15e6o2_dialog_1a" = "¡Estoy harto de que zarandeen! ¡Esta es mi caverna! Tira el arma y te dejaré salir de aquí.";
"enc_c15e6o3_dialog_1a" = "¡Tus hombres son ahora mis hombres! ¡Tus minas son ahora mis minas! ¡Esta caverna ahora es mía y tú estás invadiendo mi propiedad!";
"enc_c15e6o3_dialog_1b" = "¡Lárgate!";

//Encounter 7 - Will Shane
"enc_c15e7o1_dialog_1a" = "¡Blakk! ¡No permitiré que eches a esta gente de su tierra solo para que hagas pasar un tren por aquí!";
"enc_c15e7o2_dialog_2a" = "¡No puedes interponerte al progreso, Shane! ¡El Slugterra exprés es el futuro!";
"enc_c15e7o1_dialog_3a" = "¡Hoy me has derrotado, pero no estás por encima de la ley!";
"enc_c15e7o2_dialog_3a" = "¡Ahí es donde te equivocas! ¡Los ricos y poderosos hacen las leyes! ¡Yo soy la ley!";
"enc_c15e7o1_dialog_4a" = "Te equivocas. Eres mala persona y los slugs no quieren luchar para ti. ¡Puedo verlo en sus ojos!";
"enc_c15e7o2_dialog_4a" = "¡Todos se doblegarán a mi voluntad, hasta los slugs! No son más que herramientas que me ayudarán a construir mi imperio.";

//Encounter 8 - Brimestone
"enc_c15e8o1_dialog_1a" = "¿Dónde estoy?";
"enc_c15e8o1_dialog_2a" = "¡El poder es la única moneda aquí!";
"enc_c15e8o1_dialog_2b" = "¡Te has ganado tu lugar! Permíteme ofrecerte algo a cambio.";

//Encounter 10 - Will Shane
"enc_c15e10o1_dialog_1a" = "¿Por qué me has traído aquí, Blakk?";
"enc_c15e10o2_dialog_2a" = "¡Eres como una piedra en el zapato! Tengo una cantidad de poder que jamás imaginarías.";
"enc_c15e10o1_dialog_3a" = "¿Qué has hecho?";
"enc_c15e10o2_dialog_3a" = "¡He sometido a los slugs a mi voluntad! ¡He desatado su verdadero poder!";

//Encounter 11 - Dr.Blakk
"enc_c15e11o1_dialog_1a" = "Como ves, Eli, estás justo en el lugar en el que derroté a Will Shane.";
"enc_c15e11o1_dialog_2a" = "¿¡Qué le has hecho a mi padre!?";
"enc_c15e11o1_dialog_3a" = "Desapareció en la oscuridad. ¡No quedó ni su sombra!";
"enc_c15e11o1_dialog_3b" = "Pero la historia no acaba aquí, Eli Shane. Mis planes están tomando forma y pronto todo estará claro.";
"enc_c15e11o1_dialog_3c" = "¡Ah, ya los oigo venir!";

/* End Chapter 15 */

/* Chapter 16 */


//Encounter 1 - Delta Operator
"enc_c16e1o1_dialog_1a" = "¡Vuelve! ¡Esta gente no ha hecho nada!";
"enc_c16e1o1_dialog_2a" = "¡Fuerza Alfa enfrentándose al enemigo!";
"enc_c16e1o2_dialog_1a" = "¡Retirada! ¡Formación escalonada!";

//Encounter 2 - Doombot 1.0
"enc_c16e2o1_dialog_1a" = "10011011010101001";

//Encounter 3 - Mr. Orange
"enc_c16e3o1_dialog_1a" = "¡Fuerza Delta atacando!";

//Encounter 4 - Locke and Load
"enc_c16e4o1_dialog_1a" = "¿Qué haces aquí, Locke?";
"enc_c16e4o1_dialog_2a" = "¡El jefe dijo que creáramos una distracción y eso hacemos!";
"enc_c16e4o2_dialog_1a" = "Dr. Blakk quiere que lo dejes en paz. ¡Tiene un plan y no planea contártelo!";
"enc_c16e4o2_dialog_2a" = "¡Gracias! ¡No se lo diré a nadie!";

//Encounter 5 - Darkbane Drek and Darkbane Hartag
"enc_c16e5o1_dialog_1a" = "¿Adónde llevas los Darkbane?";
"enc_c16e5o2_dialog_1a" = "¡Graaah! ¡Súbete al carro!";
"enc_c16e5o2_dialog_1b" = "¡Gruuugh!";

//Encounter 6 - Prison Warden
"enc_c16e6o1_dialog_1a" = "¡Te he escrito un poema!";
"enc_c16e6o1_dialog_1b" = "Ya estamos...";
"enc_c16e6o2_dialog_1a" = "El fuego arde en llamas en la profunda oscuridad; ¿qué Darkbane podría equiparar su bravosidad?";
"enc_c16e6o3_dialog_1a" = "¡Vaya, sí que has mejorado!";

//Encounter 7 - Nacho
"enc_c16e7o1_dialog_1a" = "¡Se aproxima una oleada oscura! ¡La sombra se cruza en tu camino, Shane! ¡Se han forjado nuevas alianzas!";
"enc_c16e7o2_dialog_2a" = "¡No dejaré que les hagas daño!";

//Encounter 8 - Bonus Round - Prison Wagon

//Encounter 9 - Titan
"enc_c16e10o1_dialog_1a" = "¿Dónde están los abrelatas cuando más los necesitas?";

//Encounter 10 - Angry Nacho
"enc_c16e11o1_dialog_1a" = "¿Crees que puedes ganar? El Darkbane recuperará sus tierras.";
"enc_c16e11o1_dialog_2a" = "Te he detenido antes, puedo volver a hacerlo.";
"enc_c16e11o1_dialog_3a"= "¡Un ejército espera para invadir Slugterra en la oscuridad!";
"enc_c16e11o1_dialog_3b" = "¿Dónde está el ejército?";
"enc_c16e11o1_dialog_3c" = "Disfruta de tus últimos días de paz. ¡El Dr. Blakk está preparando su plan!";

/* End Chapter 16 */

/* Chapter 17 */


//Encounter 1 - Red Hook
"enc_c17e1o1_dialog_1a" = "Garfio Rojo... tienes un aspecto diferente...";
"enc_c17e1o2_dialog_1a" = "¡Desenfunda tu arma Eli!";
"enc_c17e1o3_dialog_1a" = "¡¿!?¡¿!?";
"enc_c17e1o1_dialog_2a" = "Bueno, ahora ya lo sabes. ¡Es una trampa! No deberías haber venido aquí.";
"enc_c17e1o2_dialog_2a" = "¿Qué has hecho Garfio Rojo?";
"enc_c17e1o1_dialog_3a" = "Eli, ¡gracias al cielo que has venido! El doctor Blakk ha intentado secuestrarme. Está trabajando en algo terrible, una máquina...";
"enc_c17e1o2_dialog_3a" = "¡Sea lo que sea no puede ser bueno!";
"enc_c17e1o3_dialog_3a" = "¡Tienes que ir a la ciudad y detener a Blakk!";

//Encounter 2 - Darkbane Guards
"enc_c17e2o1_dialog_1a" = "¿Veneno Oscuro? ¡¿¡¿Aquí?!?!";
"enc_c17e2o2_dialog_1a" = "El Doctor Blakk nos ordenó trabajar con los Veneno Oscuro, pero nos dan un poco de miedo.";
"enc_c17e2o3_dialog_1a" = "¡¡¡Graaaarrrrrrrrr!!!";

//Encounter 3 - Nacho
"enc_c17e3o1_dialog_1a" = "¡Sabía que vendrías, Eli! No puedes dejar de ser el héroe.";
"enc_c17e3o2_dialog_1a" = "¡Fuera de mi camino, Nacho!";

//Encounter 4 - Technician
"enc_c17e4o1_dialog_1a" = "¡Se supone que no deberías estar aquí! Estos diablos son peligrosos.";

//Encounter 5 - Bonus Round

//Encounter 6 - Elite Guard
"enc_c17e6o1_dialog_1a" = "¡Alto! ¡Área restringida!";
"enc_c17e6o2_dialog_1a" = "¡Código rojo! Intruso en el nivel tres.";

//Encounter 7 - Dr Blakk
