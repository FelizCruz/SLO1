"enc_c2e7o2_dialog_1a" = "No peleas limpio!";
"enc_c2e7o2_dialog_2a" = "Sólo sigo dos reglas. Ganar cada duelo y no perder nunca.";

"enc_c2e7o3_dialog_1a" = "Sólo queda uno…o una";
