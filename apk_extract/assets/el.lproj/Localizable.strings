/* Chapter 1 */

//Encounter 1
"enc_c1e1o1_dialog_1a" = "Τέλεια! Πάντα ήθελα να γνωρίσω ένα τρολ!";
"enc_c1e1o1_dialog_2a" = "Είμαι ο Κόρντ Ζέιν. Δεν είσαι από εδώ γύρω, σωστά;";
"enc_c1e1o1_dialog_2b" = "Ας σε διδάξω πώς να υπερασπίζεσαι τον εαυτό σου. Κοίτα τα εικονίδια κάτω.";
"enc_c1e1o1_dialog_3a" = "Κούνησε τα εικονίδια ακουμπώντας ένα και σέρνοντάς το προς το διπλανό.";
"enc_c1e1o1_dialog_4a" = "Καλή δουλειά, νεαρέ. Αρκετά.";
"enc_c1e1o1_dialog_5a" = "ΟΚ, Ηλάι, θα σου δείξω πώς να συνδυάζεις τα εικονίδια τώρα.";
"enc_c1e1o1_dialog_6a" = "Τώρα δες εάν μπορείς να συνδυάσεις τρία μαζί.";
"enc_c1e1o1_dialog_7a" = "Ουφ! Αυτή ήταν η πρώτη βολή που έριξες ποτέ; Δεν μπορώ να καταλάβω πώς κατάφερες να με πετύχεις.";
"enc_c1e1o1_dialog_7b" = "Βάζω στοίχημα ότι δεν μπορείς να το ξανακάνεις.";
"enc_c1e1o1_dialog_8a" = "Κούνησε τα εικονίδια για να κάνεις κι άλλο συνδυασμό!";
"enc_c1e1o1_dialog_9a" = "Άουτς! ΟΚ, ώστε είσαι αρκετά καλός στις βολές λοιπόν… αλλά δεν είσαι ο μόνος με εκτοξευτή! Ας μονομαχήσουμε!";
"enc_c1e1o1_dialog_10a" = "Ου, Ο! Ουφ! Γιατί το έκανες αυτό; Α, σωστά, εγώ σου το είπα…";

//Encounter 2
"enc_c1e2o1_dialog_1a" = "Πολύ καλή δουλειά, νεαρέ! Επόμενο βήμα: ανάρρωση.";
"enc_c1e2o1_dialog_2a" = "Συνδύασε τρία πράσινα εικονίδια γιατρειάς για να ξαναγεμίσεις την μπάρα υγείας σου.";
"enc_c1e2o1_dialog_3a" = "Αισθάνεσαι καλύτερα; Ωραία!";
"enc_c1e2o1_dialog_4a" = "Συγγνώμη, ο εκτοξευτής μου είναι λίγο ευαίσθητος. Καλύτερα να θεραπευτείς ξανά.";
"enc_c1e2o1_dialog_5a" = "Προσπάθησε να συνδυάσεις τέσσερα εικονίδια υγείας.";
"enc_c1e2o1_dialog_6a" = "Όσο περισσότερα εικονίδια μπορείς να συνδυάσεις με μία κίνηση, τόσο το καλύτερο!";
"enc_c1e2o1_dialog_6b" = "Τώρα ας δούμε πόσο μπορείς να αντέξεις σε μια μονομαχία.";
"enc_c1e2o1_dialog_7a" = "Πφφ… Ήμουν τόσο κοντά στο να κερδίσω.";
"enc_c1e2o1_dialog_8a" = "Δεν υποτίθεται πως θα με δίδασκες;";
"enc_c1e2o1_dialog_9a" = "Ναι, σωστά. Εε…ήταν μια δοκιμασία αυτό…και πέρασες!";

//Encounter 3
"enc_c1e3o1_dialog_1a" = "Φίλε! Αυτό που έχεις εκεί είναι σαλιγκάρι Ινφέρνους;";
"enc_c1e3o1_dialog_2a" = "Το λένε Μπέρμπι. Είναι φανταστικός!";
"enc_c1e3o1_dialog_3a" = "Τα σαλιγκάρια Ινφέρνους μεταμορφώνονται σε πανίσχυρα πλάσματα της φωτιάς.";
"enc_c1e3o1_dialog_4a" = "Ο Μπέρμπι θέλει να εξασκηθεί στη μεταμόρφωση.";
"enc_c1e3o1_dialog_5a" = "Συνδύασε εικονίδια της φωτιάς για να ενδυναμώσεις την επίθεση του Μπέρμπι.";
"enc_c1e3o1_dialog_6a" = "Συνέχισε! Χρειάζεται περισσότερο.";
"enc_c1e3o1_dialog_7a" = "Συνδυάζοντας πέντε εικονίδια φωτιάς ο Μπέρμπι θα φορτιστεί κατευθείαν ένα επίπεδο.";
"enc_c1e3o1_dialog_8a" = "Τώρα που ο Μπέρμπι δυνάμωσε, κάνε κλικ στο σαλιγκάρι σου για να απελευθερώσει τη νέα του επίθεση!";
"enc_c1e3o1_dialog_9a" = "ΕΕΕ! ΟΚ. Νομίζω πως τα καταφέρνεις μια χαρά. Μονομαχία!";
"enc_c1e3o1_dialog_10a" = "Άουτς! Την επόμενη φορά προσπάθησε να μη μου κάψεις το παντελόνι!";
"enc_c1e3o1_dialog_10b" = "Νομίζω ότι πρέπει να ετοιμαστείς για την πρώτη σου αληθινή μονομαχία! PRONTO!!!";

/* End Chapter 1 */

