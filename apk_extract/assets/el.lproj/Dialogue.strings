//Encounter 9
"enc_c5e9o1_dialog_1a" = "Όταν ο πατέρας σου σου μιλούσε για τέρατα που παραμονεύουν στο σκοτάδι, μιλούσε για μένα, Σέιν.";
"enc_c5e9o1_dialog_1b" = "Είμαι όλα αυτά που έχεις μάθει να φοβάσαι. Είμαι το σκότος. Είμαι η απόγνωση.";
"enc_c5e9o1_dialog_1c" = "Είμαι όλα τα γκουλ, είμαι τα φαντάσματα, είμαι τα τελώνια. Είμαι ο χειρότερός σου εφιάλτης, Ηλάι Σέιν.";
"enc_c5e9o1_dialog_2a" = "Ο πατέρας μου μιλούσε και για άλλα. Ότι τα τέρατα πάντα αποτυγχάνουν γιατί νομίζουν ότι ο φόβος τα δυναμώνει…";
"enc_c5e9o1_dialog_2b" = "Αλλά εγώ δε σε φοβάμαι.";
"enc_c5e9o1_dialog_3a" = "Ηττήθηκες, Nacho. Τώρα πες μου πού είναι ο Blakk.";

//Encounter 10
"enc_c5e10o1_dialog_1a" = "Μπορείς να το παλέψεις όσο θέλεις, αλλά ΕΓΩ θα κυβερνήσω όλη τη Slugterra.";
"enc_c5e10o1_dialog_1b" = "Βρίσκεται στα γρανάζια μια νέα τάξη πραγμάτων και εσύ, Ηλάι Σέιν, θα συνθλιβείς κατά τη διάρκεια.";
"enc_c5e10o1_dialog_2a" = "Θα κυβερνήσεις μια άχρηστη γη. Χωρίς τα σαλιγκάρια, η Slugterra δε θα επιβιώσει.";
"enc_c5e10o1_dialog_3a" = "ΑΑΑΡΡΡΓΚΚΚΚ!";

"enc_c5e10o2_dialog_1a" = "ΔΕ…ΘΑ…ΜΕ…ΣΤΑΜΑΤΗΣΕΙΣ!!!";
"enc_c5e10o2_dialog_2a" = "Τελείωσε, Burpy! Τα καταφέραμε! Σταματήσαμε τον Blakk!";

