"enc_c5e4o1_dialog_4b" = "Το Doombot 2.0 θα γίνει ζωγράφος και θα προσφέρει στην κοινωνία μέσω της τέχνης.";

//Encounter 5
"enc_c5e5o1_dialog_1a" = "Νόμιζα πως είπες ότι δεν είσαι μαριονέτα του Blakk.";
"enc_c5e5o1_dialog_2a" = "Ο Blakk διπλασίασε την πληρωμή μου. Ο κύριος Saturday ξέρει να αναγνωρίσει μια καλή προσφορά.";
