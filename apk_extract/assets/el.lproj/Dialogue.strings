"enc_c5e7o1_dialog_4a" = "Πρέπει να βρω τον Blakk και να βάλω ένα τέλος.";

//Encounter 8
"enc_c5e8o1_dialog_1a" = "Η Συμμορία Σέιν έπεσε κατευθείαν στην παγίδα μας λοιπόν. Κλειδώστε και φορτώστε!";
"enc_c5e8o1_dialog_1b" = "Μόλις σε νικήσω, θα δώσω στον Blakk να μετατρέψει σε γκουλ όλα σου τα σαλιγκάρια!";
