/* Chapter 5 */


//Encounter 1
"enc_c5e1o1_dialog_1a" = "Ο Δόκτωρ Blakk έκανε όλα μου τα σαλιγκάρια πολύ δυνατότερα. Αυτή τη φορά δε θα χάσω!";
"enc_c5e1o1_dialog_2a" = "Επέτρεψες στο Δόκτορα Blakk να διαβρώσει τα σαλιγκάρια σου! Μπορώ να τα επαναφέρω. Άφησέ με να βοηθήσω.";
