"enc_c3e9o2_dialog_1a" = "Εκπληξη!";

"enc_c3e9o3_dialog_1a" = "Ίδιος ο πατέρας σου! Δεν μπορούμε να έχουμε έναν Σέιν να μπλέκεται στις δουλειές μας! ";
"enc_c3e9o3_dialog_2a" = "Δεν τελειώσαμε εδώ, Ηλάι Σέιν! Ο Δόκτωρ Blakk είναι ένας πανίσχυρος άντρας και πάντα παίρνει αυτό που θέλει!";

//Encounter 10

//Encounter 11
"enc_c3e11o1_dialog_1a" = "Τι έκανες σ' αυτό το σαλιγκάρι;";
